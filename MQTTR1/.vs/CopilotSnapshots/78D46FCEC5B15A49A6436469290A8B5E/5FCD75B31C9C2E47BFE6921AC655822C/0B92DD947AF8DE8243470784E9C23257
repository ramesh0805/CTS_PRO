.devices {
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;

    .actions {
      display: flex;
      gap: 10px;
    }
  }

  .form-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }

  .btn-sm {
    padding: 8px 16px;
    font-size: 13px;
    margin-right: 8px;
    min-width: 70px;
    text-align: center;
    display: inline-block;

    &:last-child {
      margin-right: 0;
    }
  }

  // Action buttons container
  td {
    .btn-sm {
      margin-right: 8px;

      &:last-child {
        margin-right: 0;
      }
    }
  }
}
