using Microsoft.EntityFrameworkCore;
using MQTTR1.Data;
using MQTTR1.Models;

namespace MQTTR1.Repositories;

public class TelemetryRepository : ITelemetryRepository
{
    private readonly ApplicationDbContext _context;

    public TelemetryRepository(ApplicationDbContext context)
    {
        _context = context;
    }

    public async Task<Telemetry> CreateAsync(Telemetry telemetry)
    {
        _context.Telemetries.Add(telemetry);
        await _context.SaveChangesAsync();
        return telemetry;
    }

    public async Task<(IEnumerable<Telemetry> Data, int TotalCount)> GetPagedAsync(
        int page,
        int pageSize,
        string? deviceId = null,
        string? metric = null,
        DateTime? startDate = null,
        DateTime? endDate = null)
    {
        // Use AsNoTracking for better read performance since we don't modify these entities
        var query = _context.Telemetries
            .AsNoTracking()
            .Include(t => t.Device)
            .AsQueryable();

        // Apply filters in optimal order (most selective first)
        if (!string.IsNullOrEmpty(deviceId))
        {
            query = query.Where(t => t.Device.DeviceId == deviceId);
        }

        if (!string.IsNullOrEmpty(metric))
        {
            query = query.Where(t => t.Metric == metric);
        }

        // Date filters together for index usage
        if (startDate.HasValue && endDate.HasValue)
        {
            query = query.Where(t => t.Timestamp >= startDate.Value && t.Timestamp <= endDate.Value);
        }
        else if (startDate.HasValue)
        {
            query = query.Where(t => t.Timestamp >= startDate.Value);
        }
        else if (endDate.HasValue)
        {
            query = query.Where(t => t.Timestamp <= endDate.Value);
        }

        // Get count before pagination for efficiency
        var totalCount = await query.CountAsync();

        // Apply ordering and pagination
        var data = await query
            .OrderByDescending(t => t.Timestamp)
            .Skip((page - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();

        return (data, totalCount);
    }

    public async Task<Telemetry?> GetLastValueAsync(string deviceId, string metric)
    {
        // Use AsNoTracking for read-only operation
        // Use direct DeviceId comparison instead of navigation property for better performance
        return await _context.Telemetries
            .AsNoTracking()
            .Where(t => t.Device.DeviceId == deviceId && t.Metric == metric)
            .OrderByDescending(t => t.Timestamp)
            .Select(t => new Telemetry
            {
                Id = t.Id,
                DeviceId = t.DeviceId,
                Metric = t.Metric,
                Value = t.Value,
                Timestamp = t.Timestamp,
                Device = t.Device
            })
            .FirstOrDefaultAsync();
    }

    public async Task<Dictionary<string, double>> GetHourlyAverageAsync(
        string deviceId,
        string metric,
        DateTime startDate,
        DateTime endDate)
    {
        var telemetries = await _context.Telemetries
            .Include(t => t.Device)
            .Where(t => t.Device.DeviceId == deviceId 
                && t.Metric == metric 
                && t.Timestamp >= startDate 
                && t.Timestamp <= endDate)
            .ToListAsync();

        var hourlyAverages = telemetries
            .GroupBy(t => new DateTime(t.Timestamp.Year, t.Timestamp.Month, t.Timestamp.Day, t.Timestamp.Hour, 0, 0))
            .ToDictionary(
                g => g.Key.ToString("yyyy-MM-dd HH:00"),
                g => g.Average(t => t.Value)
            );

        return hourlyAverages;
    }
}
