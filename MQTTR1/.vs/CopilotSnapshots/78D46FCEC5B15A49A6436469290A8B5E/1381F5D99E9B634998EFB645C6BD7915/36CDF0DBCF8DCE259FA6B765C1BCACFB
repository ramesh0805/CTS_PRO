.devices {
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;

    .actions {
      display: flex;
      gap: 10px;
    }
  }

  .form-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }

  .btn-sm {
    padding: 8px 16px;
    font-size: 13px;
    margin-right: 8px;
    min-width: 70px;
    text-align: center;
    display: inline-block;

    &:last-child {
      margin-right: 0;
    }
  }

  // Clickable rows for admin users
  tr.clickable {
    cursor: pointer;
    transition: background-color 0.2s ease;

    &:hover {
      background-color: rgba(99, 102, 241, 0.1);
    }
  }

  // Delete section in modal
  .delete-section {
    padding: 10px 20px;
    border-bottom: 1px solid #e5e7eb;
    text-align: right;

    .btn-danger {
      font-size: 13px;
      padding: 6px 12px;
    }
  }
}
