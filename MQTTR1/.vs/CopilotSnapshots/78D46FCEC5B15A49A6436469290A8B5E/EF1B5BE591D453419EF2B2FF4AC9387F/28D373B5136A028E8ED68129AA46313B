.user-management {
  padding: 20px;
  max-width: 1400px;
  margin: 0 auto;

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;

    h1 {
      margin: 0;
      color: #333;
      font-size: 2rem;
    }
  }

  .alert {
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-weight: 500;

    &.alert-success {
      background-color: #d4edda;
      color: #155724;
      border: 1px solid #c3e6cb;
    }

    &.alert-error {
      background-color: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
    }
  }

  .loading {
    text-align: center;
    padding: 40px;
    font-size: 1.2rem;
    color: #666;
  }

  .table-container {
    background: white;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    overflow-x: auto;
  }

  .table {
    width: 100%;
    border-collapse: collapse;

    thead {
      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #d946ef 100%);
      color: white;

      th {
        padding: 15px;
        text-align: left;
        font-weight: 700;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
      }
    }

    tbody {
      tr {
        border-bottom: 1px solid #eee;
        transition: background-color 0.2s;

        &:hover {
          background-color: #f8f9fa;
        }

        td {
          padding: 15px;
          vertical-align: middle;

          &.actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
          }
        }
      }
    }
  }

  .badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-right: 8px;

    &.badge-admin {
      background-color: #ff6b6b;
      color: white;
    }

    &.badge-user {
      background-color: #4ecdc4;
      color: white;
    }

    &.badge-active {
      background-color: #51cf66;
      color: white;
    }

    &.badge-inactive {
      background-color: #868e96;
      color: white;
    }

    &.badge-protected {
      background-color: #ffd43b;
      color: #333;
      font-weight: 700;
      animation: pulse-protected 2s ease-in-out infinite;
    }
  }

  .private-info {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 12px;
    background-color: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #666;
    font-style: italic;
  }

  @keyframes pulse-protected {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(255, 212, 59, 0.7);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(255, 212, 59, 0);
    }
  }

  .btn {
    padding: 10px 20px;
    border: none;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;

    &:disabled {
      opacity: 0.5;
      cursor: not-allowed;

      &:hover {
        transform: none;
        box-shadow: none;
      }
    }

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }

    &.btn-primary {
      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #d946ef 100%);
      color: white;

      &:hover {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #c026d3 100%);
      }
    }

    &.btn-secondary {
      background-color: #868e96;
      color: white;

      &:hover {
        background-color: #6c757d;
      }
    }

    &.btn-success {
      background-color: #51cf66;
      color: white;

      &:hover {
        background-color: #40c057;
      }
    }

    &.btn-info {
      background-color: #339af0;
      color: white;

      &:hover {
        background-color: #228be6;
      }
    }

    &.btn-warning {
      background-color: #ffd43b;
      color: #333;

      &:hover {
        background-color: #fab005;
      }
    }

    &.btn-danger {
      background-color: #ff6b6b;
      color: white;

      &:hover {
        background-color: #fa5252;
      }
    }

    &.btn-sm {
      padding: 6px 12px;
      font-size: 0.85rem;
    }
  }

  .no-data {
    text-align: center;
    padding: 40px;
    color: #999;
    font-size: 1.1rem;
  }

  // Modal styles
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;

    .modal-content {
      background: white;
      border-radius: 12px;
      width: 90%;
      max-width: 500px;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px;
      border-bottom: 1px solid #eee;
      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #d946ef 100%);
      color: white;
      border-radius: 12px 12px 0 0;

      h2 {
        margin: 0;
        font-size: 1.5rem;
      }

      .close-btn {
        background: transparent;
        border: none;
        color: white;
        font-size: 1.8rem;
        cursor: pointer;
        padding: 0;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s;

        &:hover {
          transform: scale(1.2);
        }
      }
    }

    .modal-body {
      padding: 20px;
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      padding: 20px;
      border-top: 1px solid #eee;
    }
  }

  .form-group {
    margin-bottom: 20px;

    label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      color: #333;
      font-size: 0.95rem;

      &.checkbox-label {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;

        input[type="checkbox"] {
          width: 20px;
          height: 20px;
          cursor: pointer;
        }
      }
    }

    .form-control {
      width: 100%;
      padding: 12px;
      border: 2px solid #e9ecef;
      border-radius: 6px;
      font-size: 1rem;
      transition: border-color 0.3s;

      &:focus {
        outline: none;
        border-color: #8b5cf6;
      }
    }

    select.form-control {
      cursor: pointer;
    }
  }
}
