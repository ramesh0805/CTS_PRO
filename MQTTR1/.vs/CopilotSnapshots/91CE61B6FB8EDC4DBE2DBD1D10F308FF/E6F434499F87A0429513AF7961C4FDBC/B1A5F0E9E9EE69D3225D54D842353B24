.telemetry {
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .filter-form {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
  }

  .form-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }

  .page-info {
    text-align: center;
    margin-top: 15px;
    color: #6c757d;
    font-size: 14px;
  }

  .info-message {
    text-align: center;
    color: #6c757d;
    padding: 40px;
  }
}
