import { Component, OnInit, OnDestroy } from '@angular/core';
import { CommonModule } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { DataSimulatorService } from '../../services/data-simulator.service';
import { TelemetryService } from '../../services/telemetry.service';
import { DeviceService } from '../../services/device.service';
import { TelemetryChartComponent } from '../telemetry-chart/telemetry-chart.component';
import { Device } from '../../models/device.model';
import { TelemetryDto } from '../../models/telemetry.model';
import { Subscription } from 'rxjs';

@Component({
  selector: 'app-simulator',
  standalone: true,
  imports: [CommonModule, FormsModule, TelemetryChartComponent],
  templateUrl: './simulator.component.html',
  styleUrls: ['./simulator.component.scss']
})
export class SimulatorComponent implements OnInit, OnDestroy {
  devices: Device[] = [];
  selectedDevice: Device | null = null;

  // Simulation settings
  simulationRunning = false;
  simulationInterval: any;
  updateIntervalSeconds = 5;

  // Metrics to simulate
  metrics = [
    { name: 'temperature', baseValue: 22, variance: 5, unit: '°C', color: '#ff6384' },
    { name: 'humidity', baseValue: 60, variance: 10, unit: '%', color: '#36a2eb' },
    { name: 'pressure', baseValue: 1013, variance: 5, unit: 'hPa', color: '#ffce56' }
  ];

  // Chart data
  chartDataMap: Map<string, any[]> = new Map();

  // Statistics
  statsMap: Map<string, any> = new Map();

  // Messages
  loading = false;
  error = '';
  success = '';

  // Data stream subscriptions
  private subscriptions: Subscription[] = [];

  constructor(
    private deviceService: DeviceService,
    private telemetryService: TelemetryService,
    private simulator: DataSimulatorService
  ) {}

  ngOnInit(): void {
    this.loadDevices();
  }

  ngOnDestroy(): void {
    this.stopSimulation();
    this.subscriptions.forEach(sub => sub.unsubscribe());
  }

  loadDevices(): void {
    this.loading = true;
    this.deviceService.getAllDevices().subscribe({
      next: (devices) => {
        this.devices = devices;
        if (devices.length > 0) {
          this.selectedDevice = devices[0];
          this.loadHistoricalData();
        }
        this.loading = false;
      },
      error: (err) => {
        this.error = 'Failed to load devices';
        this.loading = false;
        console.error(err);
      }
    });
  }

  onDeviceChange(): void {
    if (this.selectedDevice) {
      this.loadHistoricalData();
    }
  }

  loadHistoricalData(): void {
    if (!this.selectedDevice) return;

    this.metrics.forEach(metric => {
      const data = this.simulator.generateHistoricalData(
        this.selectedDevice!.deviceId,
        metric.name,
        50,
        metric.baseValue,
        metric.variance
      );

      const key = `${this.selectedDevice!.deviceId}-${metric.name}`;
      this.chartDataMap.set(key, data);
      this.statsMap.set(key, this.simulator.calculateStats(data));
    });
  }

  startSimulation(): void {
    if (!this.selectedDevice) {
      this.error = 'Please select a device first';
      return;
    }

    this.simulationRunning = true;
    this.error = '';
    this.success = 'Simulation started';

    this.simulationInterval = setInterval(() => {
      this.generateAndSendData();
    }, this.updateIntervalSeconds * 1000);
  }

  stopSimulation(): void {
    this.simulationRunning = false;
    if (this.simulationInterval) {
      clearInterval(this.simulationInterval);
    }
    this.success = 'Simulation stopped';
  }

  generateAndSendData(): void {
    if (!this.selectedDevice) return;

    const telemetryBatch: TelemetryDto[] = [];

    this.metrics.forEach(metric => {
      const telemetry = this.simulator.generateTelemetryData(
        this.selectedDevice!.deviceId,
        metric.name,
        metric.baseValue,
        metric.variance
      );

      telemetryBatch.push(telemetry);

      // Update chart data
      const key = `${this.selectedDevice!.deviceId}-${metric.name}`;
      const currentData = this.chartDataMap.get(key) || [];
      const updatedData = [...currentData.slice(-49), telemetry]; // Keep last 50 points
      this.chartDataMap.set(key, updatedData);
      this.statsMap.set(key, this.simulator.calculateStats(updatedData));
    });

    // Send to backend
    this.telemetryService.postTelemetryBatch(telemetryBatch).subscribe({
      next: () => {
        console.log('Telemetry batch sent successfully');
      },
      error: (err) => {
        console.error('Failed to send telemetry batch', err);
      }
    });
  }

  generateSampleData(): void {
    if (!this.selectedDevice) {
      this.error = 'Please select a device first';
      return;
    }

    this.loading = true;
    const telemetryBatch: TelemetryDto[] = [];

    this.metrics.forEach(metric => {
      const historicalData = this.simulator.generateHistoricalData(
        this.selectedDevice!.deviceId,
        metric.name,
        30,
        metric.baseValue,
        metric.variance
      );

      telemetryBatch.push(...historicalData);

      const key = `${this.selectedDevice!.deviceId}-${metric.name}`;
      this.chartDataMap.set(key, historicalData);
      this.statsMap.set(key, this.simulator.calculateStats(historicalData));
    });

    // Send all data to backend
    this.telemetryService.postTelemetryBatch(telemetryBatch).subscribe({
      next: () => {
        this.success = `Generated and sent ${telemetryBatch.length} telemetry records`;
        this.loading = false;
      },
      error: (err) => {
        this.error = 'Failed to send telemetry data';
        this.loading = false;
        console.error(err);
      }
    });
  }

  getChartData(metric: string): any[] {
    if (!this.selectedDevice) return [];
    const key = `${this.selectedDevice.deviceId}-${metric}`;
    return this.chartDataMap.get(key) || [];
  }

  getStats(metric: string): any {
    if (!this.selectedDevice) return null;
    const key = `${this.selectedDevice.deviceId}-${metric}`;
    return this.statsMap.get(key);
  }

  clearData(): void {
    this.chartDataMap.clear();
    this.statsMap.clear();
    this.success = 'Chart data cleared';
  }
}
