.dashboard {
  .stats {
    .stat-item {
      display: flex;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid #eee;

      .stat-label {
        font-weight: 600;
        color: #6c757d;
      }

      .stat-value {
        font-size: 1.5rem;
        font-weight: bold;
        color: #007bff;
      }
    }
  }

  .actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
}
