import { Component, OnInit, OnDestroy } from '@angular/core';
import { CommonModule } from '@angular/common';
import { RouterLink } from '@angular/router';
import { DeviceService } from '../../services/device.service';
import { TelemetryService } from '../../services/telemetry.service';
import { AuthService } from '../../services/auth.service';
import { Device } from '../../models/device.model';
import { forkJoin, interval, Subscription } from 'rxjs';
import { switchMap } from 'rxjs/operators';

interface LiveMetric {
  name: string;
  value: number;
  unit: string;
  min: number;
  max: number;
  average: number;
  icon: string;
  color: string;
  interpretation: string;
}

@Component({
  selector: 'app-dashboard',
  standalone: true,
  imports: [CommonModule, RouterLink],
  templateUrl: './dashboard.component.html',
  styleUrls: ['./dashboard.component.scss']
})
export class DashboardComponent implements OnInit, OnDestroy {
  devices: Device[] = [];
  totalDevices: number = 0;
  recentTelemetry: any[] = [];
  loading: boolean = true;
  error: string = '';
  isAdmin: boolean = false;

  // Carousel & Live Data
  currentTime: string = '';
  currentCarouselIndex: number = 0;
  liveMetrics: LiveMetric[] = [];
  private carouselInterval?: any;
  private timeInterval?: any;
  private dataRefreshSubscription?: Subscription;

  constructor(
    private deviceService: DeviceService,
    private telemetryService: TelemetryService,
    private authService: AuthService
  ) {}

  ngOnInit(): void {
    this.loadDashboard();
    this.startTimeUpdate();
    this.startCarousel();
    this.startLiveDataRefresh();
  }

  ngOnDestroy(): void {
    if (this.carouselInterval) {
      clearInterval(this.carouselInterval);
    }
    if (this.timeInterval) {
      clearInterval(this.timeInterval);
    }
    if (this.dataRefreshSubscription) {
      this.dataRefreshSubscription.unsubscribe();
    }
  }

  loadDashboard(): void {
    this.loading = true;
    this.error = '';

    this.deviceService.getAllDevices().subscribe({
      next: (devices) => {
        this.devices = devices;
        this.totalDevices = devices.length;
        this.loadLiveMetrics();
        this.loading = false;
      },
      error: (err) => {
        this.error = 'Failed to load dashboard data';
        this.loading = false;
        console.error(err);
      }
    });
  }

  loadLiveMetrics(): void {
    if (this.devices.length === 0) return;

    // Fetch hourly telemetry for all devices (last 10 hours only)
    const telemetryRequests = this.devices.map(device =>
      this.telemetryService.getHourlyData(device.deviceId)
    );

    forkJoin(telemetryRequests).subscribe({
      next: (results) => {
        // Combine all hourly telemetry data
        const allTelemetry: any[] = [];

        results.forEach((result: any) => {
          if (result.metrics && Array.isArray(result.metrics)) {
            // Handle response with metrics array (when no metric filter)
            result.metrics.forEach((metricGroup: any) => {
              if (metricGroup.data && Array.isArray(metricGroup.data)) {
                metricGroup.data.forEach((dataPoint: any) => {
                  allTelemetry.push({
                    metric: dataPoint.metric,
                    value: dataPoint.averageValue,
                    timestamp: dataPoint.hour
                  });
                });
              }
            });
          } else if (result.data && Array.isArray(result.data)) {
            // Handle response with data array (when metric filter applied)
            result.data.forEach((dataPoint: any) => {
              allTelemetry.push({
                metric: dataPoint.metric,
                value: dataPoint.averageValue,
                timestamp: dataPoint.hour
              });
            });
          }
        });

        // Calculate metrics from hourly averages (last 10 hours only)
        const temperatures = allTelemetry
          .filter(t => t.metric === 'temperature')
          .map(t => t.value);

        const humidity = allTelemetry
          .filter(t => t.metric === 'humidity')
          .map(t => t.value);

        const pressure = allTelemetry
          .filter(t => t.metric === 'pressure')
          .map(t => t.value);

        this.liveMetrics = [
          {
            name: 'Temperature',
            value: temperatures.length > 0 ? temperatures[0] : 0,
            unit: '°C',
            min: temperatures.length > 0 ? Math.min(...temperatures) : 0,
            max: temperatures.length > 0 ? Math.max(...temperatures) : 0,
            average: temperatures.length > 0 ? temperatures.reduce((a, b) => a + b, 0) / temperatures.length : 0,
            icon: '🌡️',
            color: '#ff6b6b',
            interpretation: this.getTemperatureInterpretation(temperatures.length > 0 ? temperatures[0] : 0)
          },
          {
            name: 'Humidity',
            value: humidity.length > 0 ? humidity[0] : 0,
            unit: '%',
            min: humidity.length > 0 ? Math.min(...humidity) : 0,
            max: humidity.length > 0 ? Math.max(...humidity) : 0,
            average: humidity.length > 0 ? humidity.reduce((a, b) => a + b, 0) / humidity.length : 0,
            icon: '💧',
            color: '#4ecdc4',
            interpretation: this.getHumidityInterpretation(humidity.length > 0 ? humidity[0] : 0)
          },
          {
            name: 'Pressure',
            value: pressure.length > 0 ? pressure[0] : 0,
            unit: ' hPa',
            min: pressure.length > 0 ? Math.min(...pressure) : 0,
            max: pressure.length > 0 ? Math.max(...pressure) : 0,
            average: pressure.length > 0 ? pressure.reduce((a, b) => a + b, 0) / pressure.length : 0,
            icon: '🌪️',
            color: '#95e1d3',
            interpretation: this.getPressureInterpretation(pressure.length > 0 ? pressure[0] : 0)
          }
        ];
      },
      error: (err) => {
        console.error('Failed to load live metrics:', err);
      }
    });
  }

  getTemperatureInterpretation(temp: number): string {
    // India-specific temperature interpretations (higher baseline)
    if (temp < 15) return 'Cool for India 🥶';
    if (temp < 25) return 'Pleasant & Comfortable 😊';
    if (temp < 35) return 'Warm - Typical India Weather ☀️';
    if (temp < 40) return 'Hot - Stay Hydrated 🔥';
    return 'Very Hot - Extreme Heat! 🌡️🔥';
  }

  getHumidityInterpretation(humidity: number): string {
    if (humidity < 30) return 'Dry - Needs Moisture 🏜️';
    if (humidity < 50) return 'Comfortable Level 😊';
    if (humidity < 70) return 'Moderate - Slightly Humid 💧';
    if (humidity < 85) return 'High Humidity - Muggy 💦';
    return 'Very Humid - Monsoon Level ☔';
  }

  getPressureInterpretation(pressure: number): string {
    if (pressure < 1010) return 'Low - Possible Rain 🌧️';
    if (pressure < 1013) return 'Below Normal ⛅';
    if (pressure < 1016) return 'Normal Conditions 🌤️';
    if (pressure < 1020) return 'Stable Weather ☀️';
    return 'High - Clear Skies 🌞';
  }

  startTimeUpdate(): void {
    this.updateTime();
    this.timeInterval = setInterval(() => {
      this.updateTime();
    }, 1000);
  }

  updateTime(): void {
    // Get current time and convert to India Standard Time (IST) / Kolkata Time
    const now = new Date();

    const options: Intl.DateTimeFormatOptions = {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: true,
      timeZone: 'Asia/Kolkata'
    };

    // Use the browser's Date with Asia/Kolkata timezone for accurate IST conversion
    this.currentTime = now.toLocaleString('en-IN', options) + ' IST (Kolkata)';
  }

  startCarousel(): void {
    this.carouselInterval = setInterval(() => {
      this.nextSlide();
    }, 5000); // Change slide every 5 seconds (optimized)
  }

  startLiveDataRefresh(): void {
    // Refresh live metrics every 10 seconds
    this.dataRefreshSubscription = interval(10000)
      .pipe(switchMap(() => this.deviceService.getAllDevices()))
      .subscribe({
        next: () => {
          this.loadLiveMetrics();
        }
      });
  }

  nextSlide(): void {
    this.currentCarouselIndex = (this.currentCarouselIndex + 1) % this.liveMetrics.length;
  }

  prevSlide(): void {
    this.currentCarouselIndex = 
      (this.currentCarouselIndex - 1 + this.liveMetrics.length) % this.liveMetrics.length;
  }

  goToSlide(index: number): void {
    this.currentCarouselIndex = index;
  }

  refresh(): void {
    this.loadDashboard();
  }
}
