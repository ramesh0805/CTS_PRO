<div class="simulator">
  <div *ngIf="success" class="alert alert-success">
    {{ success }}
  </div>

  <div *ngIf="error" class="alert alert-error">
    {{ error }}
  </div>

  <div *ngIf="loading" class="loading">
    <p>Loading live data from database...</p>
  </div>

  <!-- Telemetry Submission Form -->
  <div class="card" *ngIf="selectedDevice">
    <h3>Submit Telemetry Data</h3>

    <div class="telemetry-form">
      <div class="form-row">
        <div class="form-group">
          <label for="formDevice">Device</label>
          <input 
            type="text" 
            id="formDevice" 
            [value]="selectedDevice.name + ' (' + selectedDevice.deviceId + ')'" 
            disabled
            class="form-control">
        </div>

        <div class="form-group">
          <label for="metric">Metric <span class="required">*</span></label>
          <select 
            id="metric" 
            [(ngModel)]="telemetryForm.metric"
            (ngModelChange)="onMetricChange()"
            [disabled]="submitting"
            class="form-control"
            required>
            <option *ngFor="let metric of availableMetrics" [value]="metric.name">
              {{ metric.name | titlecase }} ({{ metric.unit }})
            </option>
          </select>
          <small class="form-hint">Auto-selected based on device type</small>
        </div>

        <div class="form-group">
          <label for="value">Value <span class="required">*</span></label>
          <input 
            type="number" 
            id="value" 
            [(ngModel)]="telemetryForm.value"
            [disabled]="submitting"
            step="0.01"
            class="form-control"
            required
            placeholder="Enter value">
          <small class="form-hint" *ngIf="telemetryForm.metric">
            Unit: {{ availableMetrics.find(m => m.name === telemetryForm.metric)?.unit || '' }}
          </small>
        </div>

        <div class="form-group">
          <label for="timestamp">Timestamp</label>
          <input 
            type="datetime-local" 
            id="timestamp" 
            [(ngModel)]="telemetryForm.timestamp"
            [disabled]="submitting"
            class="form-control">
          <small class="form-hint">Leave blank for current time</small>
        </div>
      </div>

      <div class="button-group">
        <button 
          class="btn btn-primary" 
          (click)="submitTelemetry()" 
          [disabled]="submitting || !telemetryForm.metric || telemetryForm.value === null">
          <span *ngIf="!submitting">📤 Submit Telemetry</span>
          <span *ngIf="submitting">Submitting...</span>
        </button>

        <button 
          class="btn btn-secondary" 
          (click)="generateAndSubmitTelemetry()" 
          [disabled]="submitting || !telemetryForm.metric">
          🎲 Generate & Submit Random
        </button>
      </div>
    </div>
  </div>

  <!-- Controls -->
  <div class="card">
    <h3>Live Data Monitoring Controls</h3>

    <div class="controls-grid">
      <div class="form-group">
        <label for="device">Select Device</label>
        <select 
          id="device" 
          [(ngModel)]="selectedDevice" 
          (ngModelChange)="onDeviceChange()"
          [disabled]="simulationRunning">
          <option *ngFor="let device of devices" [ngValue]="device">
            {{ device.name }} ({{ device.deviceId }})
          </option>
        </select>
      </div>

      <div class="form-group">
        <label for="interval">Refresh Interval (seconds)</label>
        <input 
          type="number" 
          id="interval" 
          [(ngModel)]="updateIntervalSeconds" 
          min="30" 
          max="300"
          [disabled]="simulationRunning">
      </div>
    </div>

    <div class="button-group">
      <button 
        class="btn btn-success" 
        (click)="startSimulation()" 
        [disabled]="simulationRunning || !selectedDevice">
        <span *ngIf="!simulationRunning">Start Live Monitoring</span>
        <span *ngIf="simulationRunning">Monitoring...</span>
      </button>

      <button 
        class="btn btn-danger" 
        (click)="stopSimulation()" 
        [disabled]="!simulationRunning">
        Stop Monitoring
      </button>

      <button 
        class="btn btn-primary" 
        (click)="refreshData()" 
        [disabled]="!selectedDevice || loading">
        Refresh Data
      </button>

      <button 
        class="btn btn-secondary" 
        (click)="clearData()">
        Clear Charts
      </button>
    </div>

    <div class="info-box" *ngIf="simulationRunning">
      <span class="status-indicator active"></span>
      Live monitoring active - Refreshing data every {{ updateIntervalSeconds }} seconds from database
    </div>
  </div>

  <!-- Charts Section with Line Graphs -->
  <div *ngIf="selectedDevice">
    <div class="card chart-card" *ngFor="let metric of metrics">
      <div class="chart-header">
        <h3>{{ metric.name | titlecase }} - {{ selectedDevice.name }} (Database Values)</h3>

        <div class="stats" *ngIf="getStats(metric.name)">
          <div class="stat-item">
            <span class="stat-label">Current:</span>
            <span class="stat-value">{{ getStats(metric.name).current?.toFixed(2) }}{{ metric.unit }}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Min:</span>
            <span class="stat-value">{{ getStats(metric.name).min?.toFixed(2) }}{{ metric.unit }}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Max:</span>
            <span class="stat-value">{{ getStats(metric.name).max?.toFixed(2) }}{{ metric.unit }}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Avg:</span>
            <span class="stat-value">{{ getStats(metric.name).avg?.toFixed(2) }}{{ metric.unit }}</span>
          </div>
        </div>
      </div>

      <!-- Line Chart showing database hourly averages -->
      <app-telemetry-chart
        *ngIf="getChartData(metric.name).length > 0"
        [chartData]="getChartData(metric.name)"
        [chartLabel]="metric.name + ' (' + metric.unit + ') - Database Hourly Avg'"
        [chartType]="'line'"
        [xAxisLabel]="'Time (Hourly)'"
        [yAxisLabel]="metric.name + ' (' + metric.unit + ') from DB'">
      </app-telemetry-chart>

      <p *ngIf="getChartData(metric.name).length === 0" class="no-data">
        ✅ No database data available. Click "Refresh Data" or "Start Live Monitoring" to load from TelemetryDb.
        <br><small>Data is fetched from hourly API endpoint - no random generation.</small>
      </p>
    </div>
  </div>

  <div *ngIf="!selectedDevice" class="card">
    <p class="info-message">✅ Please select a device to view live database telemetry data (no random values).</p>
  </div>
</div>
