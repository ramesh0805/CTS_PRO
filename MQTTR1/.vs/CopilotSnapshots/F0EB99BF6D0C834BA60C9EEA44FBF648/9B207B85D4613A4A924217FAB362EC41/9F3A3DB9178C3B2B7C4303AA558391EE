import { Injectable } from '@angular/core';
import { HttpClient, HttpParams } from '@angular/common/http';
import { Observable } from 'rxjs';
import { catchError, retry, shareReplay, timeout } from 'rxjs/operators';
import { Telemetry, TelemetryDto, PagedResult } from '../models/telemetry.model';

@Injectable({
  providedIn: 'root'
})
export class TelemetryService {
  private apiUrl = 'http://localhost:5297/api/telemetry';
  private readonly CACHE_SIZE = 1;
  private readonly TIMEOUT_MS = 10000; // 10 seconds
  private readonly RETRY_COUNT = 2;

  // Cache for frequently accessed data
  private cache = new Map<string, Observable<any>>();

  constructor(private http: HttpClient) {}

  postTelemetry(telemetry: TelemetryDto): Observable<Telemetry> {
    return this.http.post<Telemetry>(this.apiUrl, telemetry).pipe(
      timeout(this.TIMEOUT_MS),
      retry(1), // Retry once on failure
      catchError(error => {
        console.error('Failed to post telemetry:', error);
        throw error;
      })
    );
  }

  postTelemetryBatch(telemetries: TelemetryDto[]): Observable<any> {
    return this.http.post(`${this.apiUrl}/batch`, telemetries).pipe(
      timeout(this.TIMEOUT_MS * 2), // Longer timeout for batch operations
      retry(1),
      catchError(error => {
        console.error('Failed to post telemetry batch:', error);
        throw error;
      })
    );
  }

  getTelemetry(deviceId?: string, metric?: string, page: number = 1, pageSize: number = 20): Observable<PagedResult<Telemetry>> {
    let params = new HttpParams()
      .set('page', page.toString())
      .set('pageSize', pageSize.toString());

    if (deviceId) {
      params = params.set('deviceId', deviceId);
    }
    if (metric) {
      params = params.set('metric', metric);
    }

    return this.http.get<PagedResult<Telemetry>>(this.apiUrl, { params }).pipe(
      timeout(this.TIMEOUT_MS),
      retry(this.RETRY_COUNT),
      shareReplay(this.CACHE_SIZE), // Cache and share the last result
      catchError(error => {
        console.error('Failed to get telemetry:', error);
        throw error;
      })
    );
  }

  getTelemetryByDevice(deviceId: string, page: number = 1, pageSize: number = 20): Observable<PagedResult<Telemetry>> {
    let params = new HttpParams()
      .set('page', page.toString())
      .set('pageSize', pageSize.toString())
      .set('deviceId', deviceId);

    return this.http.get<PagedResult<Telemetry>>(this.apiUrl, { params }).pipe(
      timeout(this.TIMEOUT_MS),
      retry(this.RETRY_COUNT),
      shareReplay(this.CACHE_SIZE),
      catchError(error => {
        console.error('Failed to get telemetry by device:', error);
        throw error;
      })
    );
  }

  getLatestTelemetry(deviceId: string, count: number = 10, metric?: string): Observable<Telemetry[]> {
    let url = `${this.apiUrl}/last?deviceId=${deviceId}&count=${count}`;
    if (metric) {
      url += `&metric=${metric}`;
    }
    return this.http.get<Telemetry[]>(url).pipe(
      timeout(this.TIMEOUT_MS),
      retry(this.RETRY_COUNT),
      shareReplay(this.CACHE_SIZE),
      catchError(error => {
        console.error('Failed to get latest telemetry:', error);
        throw error;
      })
    );
  }

  getTelemetryStats(deviceId: string, metric: string, startDate?: string, endDate?: string): Observable<any> {
    let params = new HttpParams();
    if (startDate) params = params.set('startDate', startDate);
    if (endDate) params = params.set('endDate', endDate);

    return this.http.get(`${this.apiUrl}/${deviceId}/${metric}/stats`, { params }).pipe(
      timeout(this.TIMEOUT_MS),
      retry(this.RETRY_COUNT),
      shareReplay(this.CACHE_SIZE),
      catchError(error => {
        console.error('Failed to get telemetry stats:', error);
        throw error;
      })
    );
  }

  // Get last 10 hours of hourly data for charts (10 data points)
  // Optimized with caching for frequently accessed data
  getHourlyData(deviceId: string, metric?: string): Observable<any> {
    let params = new HttpParams();
    if (metric) {
      params = params.set('metric', metric);
    }

    const cacheKey = `hourly_${deviceId}_${metric || 'all'}`;

    // Return cached observable if available
    if (this.cache.has(cacheKey)) {
      const cached = this.cache.get(cacheKey);
      if (cached) {
        return cached;
      }
    }

    // Create new observable with caching
    const request$ = this.http.get(`${this.apiUrl}/hourly/${deviceId}`, { params }).pipe(
      timeout(this.TIMEOUT_MS),
      retry(this.RETRY_COUNT),
      shareReplay({ bufferSize: 1, refCount: true, windowTime: 30000 }), // Cache for 30 seconds
      catchError(error => {
        console.error('Failed to get hourly data:', error);
        // Remove from cache on error
        this.cache.delete(cacheKey);
        throw error;
      })
    );

    // Store in cache
    this.cache.set(cacheKey, request$);

    // Clean up cache after 30 seconds
    setTimeout(() => {
      this.cache.delete(cacheKey);
    }, 30000);

    return request$;
  }

  // Clear cache manually if needed
  clearCache(): void {
    this.cache.clear();
  }
}
