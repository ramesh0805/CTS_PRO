using Microsoft.EntityFrameworkCore;
using MQTTR1.Data;
using MQTTR1.Models;

namespace MQTTR1.Services;

public class LiveTelemetryGeneratorService : BackgroundService
{
    private readonly IServiceProvider _serviceProvider;
    private readonly ILogger<LiveTelemetryGeneratorService> _logger;
    private readonly TimeSpan _generationInterval = TimeSpan.FromMinutes(5); // Generate data every 5 minutes
    private readonly Random _random = new Random();

    // Store last values for gradual changes (deviceId-metric -> lastValue)
    private readonly Dictionary<string, double> _lastValues = new Dictionary<string, double>();

    public LiveTelemetryGeneratorService(
        IServiceProvider serviceProvider,
        ILogger<LiveTelemetryGeneratorService> logger)
    {
        _serviceProvider = serviceProvider;
        _logger = logger;
    }

    protected override async Task ExecuteAsync(CancellationToken stoppingToken)
    {
        _logger.LogInformation("Live Telemetry Generator Service started. Will generate data every 5 minutes.");

        // Wait a short delay before first generation
        await Task.Delay(TimeSpan.FromSeconds(10), stoppingToken);

        // First, clean up irrelevant data on startup
        await CleanupIrrelevantDataAsync();

        // Generate initial 10 hours of historical data for charts
        await GenerateInitialHistoricalDataAsync();

        while (!stoppingToken.IsCancellationRequested)
        {
            try
            {
                await GenerateLiveTelemetryAsync();

                _logger.LogInformation("Next telemetry generation in 5 minutes at {NextRun}",
                    DateTime.UtcNow.Add(_generationInterval).ToString("yyyy-MM-dd HH:mm:ss UTC"));

                await Task.Delay(_generationInterval, stoppingToken);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error occurred during live telemetry generation.");
                await Task.Delay(TimeSpan.FromMinutes(5), stoppingToken); // Wait 5 minutes on error
            }
        }
    }

    private async Task GenerateLiveTelemetryAsync()
    {
        using var scope = _serviceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        try
        {
            // Get all devices
            var devices = await context.Devices.ToListAsync();

            if (!devices.Any())
            {
                _logger.LogWarning("No devices found. Skipping telemetry generation.");
                return;
            }

            var telemetriesToAdd = new List<Telemetry>();
            var currentTime = DateTime.UtcNow;

            foreach (var device in devices)
            {
                // Determine which metrics this device should generate based on its name/description
                var metrics = GetDeviceMetrics(device);

                foreach (var metric in metrics)
                {
                    var key = $"{device.Id}-{metric}";
                    var value = GenerateRealisticValueWithGradualChange(metric, currentTime, device.Id);

                    var telemetry = new Telemetry
                    {
                        DeviceId = device.Id,
                        Metric = metric,
                        Value = value,
                        Timestamp = currentTime
                    };

                    telemetriesToAdd.Add(telemetry);
                }
            }

            // Add all telemetry records in batch
            context.Telemetries.AddRange(telemetriesToAdd);
            await context.SaveChangesAsync();

            _logger.LogInformation(
                "Generated {Count} live telemetry records for {DeviceCount} devices at {Timestamp}",
                telemetriesToAdd.Count,
                devices.Count,
                currentTime.ToString("yyyy-MM-dd HH:mm:ss UTC"));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Failed to generate live telemetry data.");
        }
    }

    private async Task GenerateInitialHistoricalDataAsync()
    {
        using var scope = _serviceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        try
        {
            // Load the most recent values for gradual change tracking
            await LoadMostRecentValuesAsync(context);

            // Optimized check: Use AsNoTracking and count only what's needed
            var tenHoursAgo = DateTime.UtcNow.AddHours(-10);
            var recentDataCount = await context.Telemetries
                .AsNoTracking()
                .Where(t => t.Timestamp >= tenHoursAgo)
                .CountAsync();

            if (recentDataCount >= 120) // 3 devices × 40 intervals (15-min) = 120 records
            {
                _logger.LogInformation("Sufficient historical data already exists ({Count} records). Skipping backfill.", recentDataCount);
                return;
            }

            _logger.LogInformation("Generating initial 10 hours of historical telemetry data (15-minute intervals)...");

            var devices = await context.Devices.ToListAsync();
            if (!devices.Any())
            {
                _logger.LogWarning("No devices found. Skipping historical data generation.");
                return;
            }

            var telemetriesToAdd = new List<Telemetry>();

            // Generate data for last 10 hours (one record every 15 minutes per device)
            for (int minutesAgo = 600; minutesAgo >= 15; minutesAgo -= 15) // 600 minutes = 10 hours
            {
                var timestamp = DateTime.UtcNow.AddMinutes(-minutesAgo);

                foreach (var device in devices)
                {
                    var metrics = GetDeviceMetrics(device);

                    foreach (var metric in metrics)
                    {
                        var value = GenerateRealisticValueWithGradualChange(metric, timestamp, device.Id);

                        var telemetry = new Telemetry
                        {
                            DeviceId = device.Id,
                            Metric = metric,
                            Value = value,
                            Timestamp = timestamp
                        };

                        telemetriesToAdd.Add(telemetry);
                    }
                }
            }

            context.Telemetries.AddRange(telemetriesToAdd);
            await context.SaveChangesAsync();

            _logger.LogInformation(
                "Generated {Count} historical telemetry records for {DeviceCount} devices (last 10 hours, 15-min intervals)",
                telemetriesToAdd.Count,
                devices.Count);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Failed to generate initial historical telemetry data.");
        }
    }

    private async Task LoadMostRecentValuesAsync(ApplicationDbContext context)
    {
        try
        {
            // Simplified query to avoid casting issues
            // Get all telemetry and process in memory
            var recentTelemetry = await context.Telemetries
                .AsNoTracking()
                .Select(t => new { t.DeviceId, t.Metric, t.Timestamp, t.Value })
                .ToListAsync();

            _lastValues.Clear(); // Clear existing values before repopulating

            // Group in memory and get most recent value for each device-metric combination
            var grouped = recentTelemetry
                .GroupBy(t => new { t.DeviceId, t.Metric })
                .Select(g => new
                {
                    g.Key.DeviceId,
                    g.Key.Metric,
                    Value = g.OrderByDescending(x => x.Timestamp).First().Value
                });

            foreach (var item in grouped)
            {
                var key = $"{item.DeviceId}-{item.Metric}";
                _lastValues[key] = item.Value;
            }

            _logger.LogInformation("Loaded {Count} recent values for gradual change tracking", _lastValues.Count);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Failed to load recent values for gradual change tracking");
        }
    }

    private async Task CleanupIrrelevantDataAsync()
    {
        using var scope = _serviceProvider.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        try
        {
            _logger.LogInformation("Starting cleanup of irrelevant telemetry data...");

            // Get all devices
            var devices = await context.Telemetries
                .Include(t => t.Device)
                .Select(t => t.Device)
                .Distinct()
                .ToListAsync();

            int totalDeleted = 0;

            foreach (var device in devices)
            {
                // Get the correct metric(s) for this device
                var correctMetrics = GetDeviceMetrics(device);

                // Find telemetry records that don't match the device's metric
                var irrelevantRecords = await context.Telemetries
                    .Where(t => t.DeviceId == device.Id && !correctMetrics.Contains(t.Metric))
                    .ToListAsync();

                if (irrelevantRecords.Any())
                {
                    context.Telemetries.RemoveRange(irrelevantRecords);
                    totalDeleted += irrelevantRecords.Count;

                    _logger.LogInformation(
                        "Device '{DeviceName}' ({DeviceId}): Removing {Count} irrelevant '{Metrics}' records. Correct metric: {CorrectMetric}",
                        device.Name,
                        device.DeviceId,
                        irrelevantRecords.Count,
                        string.Join(", ", irrelevantRecords.Select(r => r.Metric).Distinct()),
                        string.Join(", ", correctMetrics));
                }
            }

            if (totalDeleted > 0)
            {
                await context.SaveChangesAsync();
                _logger.LogInformation(
                    "Cleanup complete: Removed {TotalDeleted} irrelevant telemetry records from database",
                    totalDeleted);
            }
            else
            {
                _logger.LogInformation("No irrelevant telemetry data found. Database is clean.");
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Failed to cleanup irrelevant telemetry data.");
        }
    }

    private List<string> GetDeviceMetrics(Device device)
    {
        var metrics = new List<string>();
        var deviceName = device.Name.ToLower();
        var deviceDesc = (device.Description ?? "").ToLower();
        var combined = deviceName + " " + deviceDesc;

        // Determine PRIMARY metric based on device type (ONLY ONE metric per device)
        // Priority: temperature > humidity > pressure
        if (combined.Contains("temperature") || combined.Contains("thermostat") || 
            combined.Contains("temp") || device.DeviceId == "device-001")
        {
            metrics.Add("temperature");
            return metrics; // Return immediately - only temperature
        }
        else if (combined.Contains("humidity") || combined.Contains("moisture") || 
            device.DeviceId == "device-002")
        {
            metrics.Add("humidity");
            return metrics; // Return immediately - only humidity
        }
        else if (combined.Contains("pressure") || combined.Contains("barometric") || 
            combined.Contains("barometer") || device.DeviceId == "device-003")
        {
            metrics.Add("pressure");
            return metrics; // Return immediately - only pressure
        }

        // If no specific metrics detected, generate temperature by default
        metrics.Add("temperature");
        return metrics;
    }

    private double GenerateRealisticValue(string metric, DateTime timestamp)
    {
        // Generate realistic values for Indian climate with smooth time-based patterns
        switch (metric.ToLower())
        {
            case "temperature":
                // India temperature: 25-48°C with daily variation
                // Hotter during day (12-18 IST), cooler at night
                var hour = timestamp.Hour;
                var istHour = (hour + 5) % 24; // Approximate IST conversion

                // Base temperature varies smoothly by time of day
                double baseTemp;
                if (istHour >= 6 && istHour < 12)
                {
                    // Morning: gradual rise from 28°C to 35°C
                    baseTemp = 28 + (istHour - 6) * 1.2;
                }
                else if (istHour >= 12 && istHour < 18)
                {
                    // Afternoon (hottest): gradual rise from 35°C to 42°C
                    baseTemp = 35 + (istHour - 12) * 1.2;
                }
                else if (istHour >= 18 && istHour < 22)
                {
                    // Evening: gradual drop from 42°C to 30°C
                    baseTemp = 42 - (istHour - 18) * 3.0;
                }
                else
                {
                    // Night: gradual drop from 30°C to 26°C
                    if (istHour >= 22)
                    {
                        baseTemp = 30 - (istHour - 22) * 2.0;
                    }
                    else // 0-6 AM
                    {
                        baseTemp = 26 + istHour * 0.3;
                    }
                }

                // Add minimal random variation (±0.5°C) for slight natural fluctuation
                return Math.Round(baseTemp + (_random.NextDouble() - 0.5), 1);

            case "humidity":
                // India humidity: 30-85% with smooth daily variation
                // More humid in morning and evening, less during afternoon
                var istHourHumidity = (timestamp.Hour + 5) % 24;
                double baseHumidity;

                if (istHourHumidity >= 6 && istHourHumidity < 12)
                {
                    // Morning: high humidity, gradually decreasing
                    baseHumidity = 75 - (istHourHumidity - 6) * 2.5;
                }
                else if (istHourHumidity >= 12 && istHourHumidity < 18)
                {
                    // Afternoon: low humidity, stable
                    baseHumidity = 45 + (istHourHumidity - 12) * 0.5;
                }
                else if (istHourHumidity >= 18 && istHourHumidity < 22)
                {
                    // Evening: humidity rising
                    baseHumidity = 48 + (istHourHumidity - 18) * 4.0;
                }
                else
                {
                    // Night: high humidity, stable
                    baseHumidity = 65 + (istHourHumidity >= 22 ? (istHourHumidity - 22) * 1.5 : istHourHumidity * 0.5);
                }

                // Add minimal random variation (±1%)
                return Math.Round(baseHumidity + (_random.NextDouble() - 0.5) * 2, 1);

            case "pressure":
                // Atmospheric pressure: 1008-1016 hPa with smooth diurnal variation
                // Typically higher in morning and evening, lower in afternoon
                var istHourPressure = (timestamp.Hour + 5) % 24;
                double basePressure;

                if (istHourPressure >= 6 && istHourPressure < 12)
                {
                    // Morning: pressure dropping slightly
                    basePressure = 1014 - (istHourPressure - 6) * 0.3;
                }
                else if (istHourPressure >= 12 && istHourPressure < 18)
                {
                    // Afternoon: lowest pressure
                    basePressure = 1012 - (istHourPressure - 12) * 0.2;
                }
                else if (istHourPressure >= 18 && istHourPressure < 22)
                {
                    // Evening: pressure rising
                    basePressure = 1011 + (istHourPressure - 18) * 0.5;
                }
                else
                {
                    // Night: stable higher pressure
                    basePressure = 1013 + (istHourPressure >= 22 ? (istHourPressure - 22) * 0.2 : istHourPressure * 0.1);
                }

                // Add minimal random variation (±0.3 hPa)
                return Math.Round(basePressure + (_random.NextDouble() - 0.5) * 0.6, 1);

            default:
                // Default smooth value
                return Math.Round(50 + (_random.NextDouble() - 0.5) * 10, 1);
        }
    }

    private double GenerateRealisticValueWithGradualChange(string metric, DateTime timestamp, int deviceId)
    {
        var key = $"{deviceId}-{metric}";

        // Get the target value based on time of day
        var targetValue = GenerateRealisticValue(metric, timestamp);

        // If we don't have a previous value, use the target
        if (!_lastValues.ContainsKey(key))
        {
            _lastValues[key] = targetValue;
            return targetValue;
        }

        var previousValue = _lastValues[key];

        // Define maximum change per hour for smooth, realistic transitions
        // These limits ensure gradual changes mimicking real-world behavior
        double maxChangePerHour;
        switch (metric.ToLower())
        {
            case "temperature":
                maxChangePerHour = 1.5; // Max ±1.5°C per hour (reduced from 2.5 for smoother changes)
                break;
            case "humidity":
                maxChangePerHour = 3.0; // Max ±3% per hour (reduced from 5 for smoother changes)
                break;
            case "pressure":
                maxChangePerHour = 0.8; // Max ±0.8 hPa per hour (reduced from 1.5 for smoother changes)
                break;
            default:
                maxChangePerHour = 2.0;
                break;
        }

        // Calculate the change needed
        var change = targetValue - previousValue;

        // Limit the change to maxChangePerHour
        if (Math.Abs(change) > maxChangePerHour)
        {
            change = change > 0 ? maxChangePerHour : -maxChangePerHour;
        }

        // Apply gradual change
        var newValue = previousValue + change;

        // Ensure we're moving towards the target but not overshooting
        if ((change > 0 && newValue > targetValue) || (change < 0 && newValue < targetValue))
        {
            newValue = targetValue;
        }

        // Store the new value for next iteration
        _lastValues[key] = newValue;

        return Math.Round(newValue, 1);
    }
}
