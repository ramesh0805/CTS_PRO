    .floating-icons {
      position: absolute;
      width: 100%;
      height: 100%;
    }

    .floating-icons .icon {
      position: absolute;
      font-size: 28px;
      opacity: 0.25;
      animation: floatIcon 18s infinite ease-in-out;
    }

    .floating-icons .icon:nth-child(1) {
      top: 15%;
      left: 15%;
      animation-delay: 0s;
    }

    .floating-icons .icon:nth-child(2) {
      top: 65%;
      left: 75%;
      animation-delay: 4s;
    }

    .floating-icons .icon:nth-child(3) {
      top: 75%;
      left: 15%;
      animation-delay: 8s;
    }

    .floating-icons .icon:nth-child(4) {
      top: 25%;
