    @keyframes pulse {
      0%, 100% {
        transform: scale(1) rotate(0deg);
        box-shadow: 0 10px 30px rgba(17, 153, 142, 0.4);
      }
      50% {
        transform: scale(1.05) rotate(180deg);
        box-shadow: 0 15px 40px rgba(17, 153, 142, 0.6);
      }
    }

    .logo-icon {
      font-size: 40px;
      filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
    }

    .card-title {
      color: #333;
      font-size: 28px;
      font-weight: 700;
