<div class="devices">
  <div class="header">
    <h1>Devices</h1>
    <div class="actions">
      <button class="btn btn-primary" (click)="showAddForm()" *ngIf="!showForm">Add Device</button>
      <button class="btn btn-secondary" (click)="refresh()">Refresh</button>
    </div>
  </div>

  <div *ngIf="success" class="alert alert-success">
    {{ success }}
  </div>

  <div *ngIf="error" class="alert alert-error">
    {{ error }}
  </div>

  <div *ngIf="showForm" class="card">
    <h3>{{ editingDevice ? 'Edit Device' : 'Add Device' }}</h3>
    <form (ngSubmit)="submitForm()">
      <div class="form-group">
        <label for="deviceId">Device ID *</label>
        <input 
          type="text" 
          id="deviceId" 
          [(ngModel)]="deviceForm.deviceId" 
          name="deviceId" 
          required
          [disabled]="editingDevice !== null">
      </div>

      <div class="form-group">
        <label for="name">Name *</label>
        <input 
          type="text" 
          id="name" 
          [(ngModel)]="deviceForm.name" 
          name="name" 
          required>
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea 
          id="description" 
          [(ngModel)]="deviceForm.description" 
          name="description">
        </textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-success">{{ editingDevice ? 'Update' : 'Create' }}</button>
        <button type="button" class="btn btn-secondary" (click)="cancelForm()">Cancel</button>
      </div>
    </form>
  </div>

  <div *ngIf="loading" class="loading">
    <p>Loading devices...</p>
  </div>

  <div *ngIf="!loading" class="card">
    <h3>Device List ({{ devices.length }})</h3>

    <table class="table" *ngIf="devices.length > 0">
      <thead>
        <tr>
          <th>ID</th>
          <th>Device ID</th>
          <th>Name</th>
          <th>Description</th>
          <th>Created</th>
          <th>Updated</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <tr *ngFor="let device of devices">
          <td>{{ device.id }}</td>
          <td>{{ device.deviceId }}</td>
          <td>{{ device.name }}</td>
          <td>{{ device.description || 'N/A' }}</td>
          <td>{{ device.createdAt | date:'short' }}</td>
          <td>{{ device.updatedAt ? (device.updatedAt | date:'short') : 'N/A' }}</td>
          <td>
            <button class="btn btn-primary btn-sm" (click)="showEditForm(device)">Edit</button>
            <button class="btn btn-danger btn-sm" (click)="deleteDevice(device)">Delete</button>
          </td>
        </tr>
      </tbody>
    </table>

    <p *ngIf="devices.length === 0">No devices found. Click "Add Device" to create one.</p>
  </div>
</div>
