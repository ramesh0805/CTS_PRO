<div class="devices">
  <div class="header">
    <div class="header-text">
      <h1>Device Explorer</h1>
      <p class="subtitle">Manage connected sensors, monitor fleet health, and maintain registration details.</p>
    </div>
    <div class="actions">
      <button class="btn btn-primary" (click)="showAddForm()" *ngIf="isAdmin()">Register Device</button>
      <button class="btn btn-secondary" (click)="refresh()">Refresh</button>
    </div>
  </div>

  <div class="fleet-summary" *ngIf="!loading">
    <div class="summary-card total">
      <span class="label">Total Devices</span>
      <span class="value">{{ devices.length }}</span>
    </div>
    <div class="summary-card connected">
      <span class="label">Connected</span>
      <span class="value">{{ connectedCount }}</span>
    </div>
    <div class="summary-card attention">
      <span class="label">Needs Attention</span>
      <span class="value">{{ attentionCount }}</span>
    </div>
  </div>

  <div *ngIf="loading" class="loading">
    <p>Loading device inventory...</p>
  </div>

  <div *ngIf="!loading" class="card">
    <div class="section-head">
      <h3>Registered Devices ({{ devices.length }})</h3>
      <p>Operational view of onboarded sensors and registration metadata.</p>
    </div>

    <table class="table" *ngIf="devices.length > 0">
      <thead>
        <tr>
          <th>ID</th>
          <th>Device ID</th>
          <th>Name</th>
          <th>Description</th>
          <th>Created</th>
          <th>Status</th>
          <th>Updated</th>
          <th *ngIf="isAdmin()">Actions</th>
        </tr>
      </thead>
      <tbody>
        <tr *ngFor="let device of devices">
          <td>{{ device.id }}</td>
          <td>{{ device.deviceId }}</td>
          <td>{{ device.name }}</td>
          <td>{{ device.description || 'N/A' }}</td>
          <td>{{ device.createdAt | date:'short' }}</td>
          <td>
            <span class="status-chip" [class.connected]="isDeviceConnected(device)" [class.attention]="!isDeviceConnected(device)">
              {{ getHealthLabel(device) }}
            </span>
          </td>
          <td>{{ device.updatedAt ? (device.updatedAt | date:'short') : 'N/A' }}</td>
          <td *ngIf="isAdmin()" class="actions">
            <button class="btn btn-sm btn-warning" (click)="showEditForm(device)">Edit</button>
            <button class="btn btn-sm btn-danger" (click)="deleteDevice(device)">Remove</button>
          </td>
        </tr>
      </tbody>
    </table>

    <p *ngIf="devices.length === 0">No devices registered yet. Use <strong>Register Device</strong> to onboard your first sensor.</p>
  </div>

  <!-- Add/Edit Form Modal with Overlay -->
  <div class="modal-overlay" *ngIf="showForm" (click)="cancelForm()"></div>
  <div class="modal" *ngIf="showForm">
    <div class="modal-content">
      <div class="modal-header">
        <h2>{{ editingDevice ? 'Edit Device Registration' : 'Register New Device' }}</h2>
        <button class="close-btn" (click)="cancelForm()">&times;</button>
      </div>

      <div class="modal-body">
        <form (ngSubmit)="submitForm()" #deviceFormElement="ngForm">
          <div class="form-group">
            <label for="deviceId">Device ID</label>
            <input
              type="text"
              id="deviceId"
              name="deviceId"
              [(ngModel)]="deviceForm.deviceId"
              class="form-control"
              required
              [disabled]="editingDevice !== null"
              placeholder="e.g., device-004">
          </div>

          <div class="form-group">
            <label for="name">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              [(ngModel)]="deviceForm.name"
              class="form-control"
              required
              placeholder="e.g., Temperature Sensor">
          </div>

          <div class="form-group">
            <label for="description">Description (Optional)</label>
            <textarea
              id="description"
              name="description"
              [(ngModel)]="deviceForm.description"
              class="form-control"
              rows="3"
              placeholder="Enter device description"></textarea>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" (click)="cancelForm()">Cancel</button>
            <button type="submit" 
                    [class]="editingDevice ? 'btn btn-warning' : 'btn btn-primary'" 
                    [disabled]="!deviceFormElement.valid">
              {{ editingDevice ? 'Update' : 'Register' }}
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
