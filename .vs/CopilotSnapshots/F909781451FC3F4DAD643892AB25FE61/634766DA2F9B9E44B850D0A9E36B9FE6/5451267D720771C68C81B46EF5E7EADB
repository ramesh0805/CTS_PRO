.telemetry {
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;

    .header-text {
      display: flex;
      flex-direction: column;
      gap: 8px;

      h1 {
        font-size: 2rem;
        font-weight: 800;
        margin: 0;
        background: linear-gradient(135deg, #312e81 0%, #2563eb 55%, #0ea5e9 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: 0.2px;
      }

      .header-subtitle {
        margin: 0;
        color: #4e5b8a;
        font-size: 0.98rem;
        line-height: 1.5;
      }
    }
  }

  .section-head {
    margin-bottom: 14px;

    h3 {
      margin: 0 0 6px;
      color: #1f2a58;
      font-size: 1.15rem;
      font-weight: 700;
    }

    p {
      margin: 0;
      color: #57628d;
      font-size: 0.92rem;
      line-height: 1.4;
    }
  }

  .filter-form {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px;
    padding: 18px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.06) 0%, rgba(14, 165, 233, 0.08) 100%);
    border: 1px solid rgba(79, 70, 229, 0.16);
  }

  .form-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }

  .readonly-input {
    background-color: #f8f9fa;
    color: #495057;
    cursor: not-allowed;
    font-weight: 500;
  }

  .table-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    gap: 12px;
    flex-wrap: wrap;

    h3 {
      margin: 0;
      color: #1f2a58;
      font-weight: 700;
    }
  }

  .chart-header {
    margin-bottom: 20px;

    h3 {
      margin-bottom: 5px;
      color: #1f2a58;
      font-weight: 700;
    }

    .chart-info {
      color: #4f5c8a;
      font-size: 0.9rem;
    }
  }

  .chart-hint-card {
    border-style: dashed;
    border-color: rgba(79, 70, 229, 0.35);
    background: linear-gradient(135deg, rgba(238, 242, 255, 0.85) 0%, rgba(224, 242, 254, 0.88) 100%);
  }

  .chart-hint-text {
    margin: 0;
    text-align: center;
    color: #374789;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .page-info {
    text-align: center;
    margin-top: 15px;
    color: #6c757d;
    font-size: 14px;
  }

  .info-message {
    text-align: center;
    color: #5b6488;
    padding: 40px;
    line-height: 1.6;
  }
}
