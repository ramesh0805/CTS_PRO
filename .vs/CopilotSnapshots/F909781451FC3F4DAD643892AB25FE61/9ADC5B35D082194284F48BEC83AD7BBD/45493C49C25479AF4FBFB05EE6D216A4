})
export class AppComponent implements OnInit {
  title = 'MQTTR Dashboard';
  currentRoute = '';
  userMenuOpen = false;

  constructor(
    public authService: AuthService,
    private router: Router,
    private telemetryMonitor: TelemetryMonitorService,
    private elementRef: ElementRef
  ) {}

  ngOnInit(): void {
    // Track current route
    this.router.events.pipe(
      filter(event => event instanceof NavigationEnd)
    ).subscribe((event: any) => {
      this.currentRoute = event.urlAfterRedirects || event.url;
      console.log('[AppComponent] Route changed to:', this.currentRoute);
    });

    // Start telemetry monitoring when user is authenticated
    this.authService.currentUser$.subscribe(user => {
      if (user) {
        console.log('[AppComponent] User authenticated, starting telemetry monitoring');
        this.telemetryMonitor.startMonitoring();
      } else {
        console.log('[AppComponent] User logged out, stopping telemetry monitoring');
        this.telemetryMonitor.stopMonitoring();
      }
    });
  }

  shouldShowNavbar(): boolean {
    // Hide navbar on login and register pages
    const publicRoutes = ['/login', '/register'];
    const isPublicRoute = publicRoutes.some(route => this.currentRoute.startsWith(route));

    if (isPublicRoute) {
      console.log('[AppComponent] Hiding navbar on public route:', this.currentRoute);
      return false;
    }

    return true;
  }

  getInitials(): string {
    const user = this.authService.getCurrentUser();
    if (!user || !user.username) {
      return '??';
    }
    return user.username.substring(0, 2).toUpperCase();
  }

  toggleUserMenu(event: Event): void {
    event.stopPropagation();
    this.userMenuOpen = !this.userMenuOpen;
  }

  closeUserMenu(): void {
    this.userMenuOpen = false;
  }

  goToAdministration(): void {
    this.closeUserMenu();
    this.router.navigate(['/user-management']);
  }

  @HostListener('document:click', ['$event'])
  onDocumentClick(event: MouseEvent): void {
    if (!this.elementRef.nativeElement.contains(event.target)) {
      this.closeUserMenu();
    }
  }

  logout(): void {
    this.closeUserMenu();
    this.authService.logout();
    this.router.navigate(['/login']);
  }
}
