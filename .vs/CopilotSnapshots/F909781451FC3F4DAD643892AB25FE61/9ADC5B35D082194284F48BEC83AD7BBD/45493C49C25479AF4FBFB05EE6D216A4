        </div>

        <ul class="navbar-menu">
          <li class="menu-item">
            <a routerLink="/dashboard" routerLinkActive="active" class="menu-link">
              <span class="menu-text">Overview</span>
            </a>
          </li>
          <li class="menu-item">
            <a routerLink="/devices" routerLinkActive="active" class="menu-link">
              <span class="menu-text">Device Explorer</span>
            </a>
          </li>
          <li class="menu-item">
            <a routerLink="/telemetry" routerLinkActive="active" class="menu-link">
              <span class="menu-text">Data Explorer</span>
