              <span class="menu-text">Administration</span>
            </a>
          </li>
        </ul>

        <div class="navbar-user">
          <app-navbar-alerts></app-navbar-alerts>

          <div class="user-menu-wrapper">
            <button class="user-pill" type="button" [class.open]="userMenuOpen" (click)="toggleUserMenu($event)" title="{{ currentUser.username }}">
              <div class="user-avatar">{{ getInitials() }}</div>
              <span class="user-name">{{ currentUser.username }}</span>
              <span class="user-caret">▾</span>
            </button>

            <div class="user-dropdown" *ngIf="userMenuOpen">
              <div class="dropdown-user">
                <span class="dropdown-label">Signed in as</span>
                <span class="dropdown-name">{{ currentUser.username }}</span>
              </div>
              <button class="dropdown-item" *ngIf="authService.isAdmin()" (click)="goToAdministration()">
                <span class="item-icon">ADM</span>
                <span>Administration</span>
              </button>
              <button class="dropdown-item danger" (click)="logout()">
                <span class="item-icon">OUT</span>
                <span>Sign out</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main class="main-content">
      <router-outlet></router-outlet>
    </main>
  `,
  styles: [`
