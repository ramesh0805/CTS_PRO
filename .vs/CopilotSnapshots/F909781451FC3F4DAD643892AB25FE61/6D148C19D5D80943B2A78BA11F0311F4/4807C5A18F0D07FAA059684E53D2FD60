import { Injectable } from '@angular/core';
import { HttpClient, HttpHeaders } from '@angular/common/http';
import { Observable, BehaviorSubject, tap, of, map, catchError } from 'rxjs';
import { environment } from '../../environments/environment';

export interface RegisterDto {
  username: string;
  email: string;
  password: string;
}

export interface LoginDto {
  username: string;
  password: string;
}

export interface AuthResponse {
  token: string;
  username: string;
  email: string;
  role: string;
  expiresAt: Date;
}

export interface UserDto {
  id: number;
  username: string;
  email: string;
  role: string;
  createdAt: Date;
}

@Injectable({
  providedIn: 'root'
})
export class AuthService {
  private apiUrl = `${environment.apiUrl}/auth`;
  private tokenKey = 'auth_token';
  private userKey = 'auth_user';

  private currentUserSubject = new BehaviorSubject<UserDto | null>(null);
  public currentUser$ = this.currentUserSubject.asObservable();

  constructor(private http: HttpClient) {
    // Initialize authentication state on service creation
    console.log('[AuthService] Initializing...');
    this.initializeAuth();
  }

  private initializeAuth(): void {
    const token = this.getToken();
    const user = this.getStoredUser();

    console.log('[AuthService] InitializeAuth - Token exists:', !!token);
    console.log('[AuthService] InitializeAuth - User exists:', !!user);

    // Only restore session if both token and user exist AND token is valid
    if (token && user && this.isTokenValid(token)) {
      console.log('[AuthService] Restoring valid session for:', user.username);
      this.currentUserSubject.next(user);
    } else {
      console.log('[AuthService] No valid session found, clearing state');
      // Clear invalid session
      this.logout();
    }
  }

  private isTokenValid(token: string): boolean {
    try {
      const payload = this.decodeToken(token);
      if (payload && payload.exp) {
        const expirationDate = new Date(payload.exp * 1000);
        const isValid = expirationDate > new Date();
        console.log('[AuthService] Token validation:', {
          expiresAt: expirationDate,
          now: new Date(),
          isValid
        });
        return isValid;
      }
      console.log('[AuthService] Token has no expiration');
      return false;
    } catch (error) {
      console.error('[AuthService] Token validation error:', error);
      return false;
    }
  }

  register(registerDto: RegisterDto): Observable<AuthResponse> {
    return this.http.post<AuthResponse>(`${this.apiUrl}/register`, registerDto).pipe(
      tap(response => this.handleAuthResponse(response))
    );
  }

  login(loginDto: LoginDto): Observable<AuthResponse> {
    return this.http.post<AuthResponse>(`${this.apiUrl}/login`, loginDto).pipe(
      tap(response => this.handleAuthResponse(response))
    );
  }

  logout(): void {
    console.log('[AuthService] Logging out');
    localStorage.removeItem(this.tokenKey);
    localStorage.removeItem(this.userKey);
    this.currentUserSubject.next(null);
  }

  getToken(): string | null {
    return localStorage.getItem(this.tokenKey);
  }

  isAuthenticated(): boolean {
    const token = this.getToken();
    const user = this.getCurrentUser();

    console.log('[AuthService] isAuthenticated check:', {
      hasToken: !!token,
      hasUser: !!user,
      username: user?.username,
      role: user?.role
    });

    // Both token and user must exist
    if (!token || !user) {
      console.log('[AuthService] Not authenticated: missing token or user');
      return false;
    }

    // Check if token is valid
    if (!this.isTokenValid(token)) {
      console.log('[AuthService] Not authenticated: invalid token');
      this.logout();
      return false;
    }

    console.log('[AuthService] Authenticated successfully');
    return true;
  }

  validateTokenWithServer(): Observable<boolean> {
    if (!this.isAuthenticated()) {
      return of(false);
    }

    return this.http.get(`${this.apiUrl}/validate`).pipe(
      map(() => true),
      catchError(() => {
        this.logout();
        return of(false);
      })
    );
  }

  private decodeToken(token: string): any {
    try {
      const base64Url = token.split('.')[1];
      const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
      const jsonPayload = decodeURIComponent(
        atob(base64)
          .split('')
          .map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2))
          .join('')
      );
      return JSON.parse(jsonPayload);
    } catch (error) {
      return null;
    }
  }

  isAdmin(): boolean {
    const user = this.currentUserSubject.value;
    const isAdmin = user?.role === 'Admin';
    console.log('[AuthService] isAdmin check:', {
      user: user?.username,
      role: user?.role,
      isAdmin
    });
    return isAdmin;
  }

  getCurrentUser(): UserDto | null {
    return this.currentUserSubject.value;
  }

  private handleAuthResponse(response: AuthResponse): void {
    localStorage.setItem(this.tokenKey, response.token);

    const user: UserDto = {
      id: 0, // Will be populated from token or separate call
      username: response.username,
      email: response.email,
      role: response.role,
      createdAt: new Date()
    };

    localStorage.setItem(this.userKey, JSON.stringify(user));
    this.currentUserSubject.next(user);
  }

  private getStoredUser(): UserDto | null {
    const userJson = localStorage.getItem(this.userKey);
    if (!userJson) {
      return null;
    }

    try {
      return JSON.parse(userJson);
    } catch {
      return null;
    }
  }

  getAuthHeaders(): HttpHeaders {
    const token = this.getToken();
    return new HttpHeaders({
      'Authorization': `Bearer ${token}`
    });
  }
}
