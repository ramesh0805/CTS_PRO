.devices {
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 20px;
    flex-wrap: wrap;

    .header-text {
      h1 {
        margin: 0 0 6px;
        font-size: 1.9rem;
        font-weight: 800;
        color: #1b2f5b;
      }

      .subtitle {
        margin: 0;
        color: #5a6691;
        font-size: 0.95rem;
        line-height: 1.5;
      }
    }

    .actions {
      display: flex;
      gap: 10px;
    }
  }

  .fleet-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 18px;

    .summary-card {
      background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
      border: 1px solid rgba(37, 99, 235, 0.2);
      border-radius: 12px;
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 4px;

      .label {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        color: #4665a8;
        font-weight: 700;
      }

      .value {
        font-size: 1.7rem;
        font-weight: 800;
        color: #163b75;
      }

      &.connected {
        background: linear-gradient(135deg, #ecfdf3 0%, #dcfce7 100%);
        border-color: rgba(34, 197, 94, 0.28);
      }

      &.attention {
        background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
        border-color: rgba(245, 158, 11, 0.32);
      }
    }
  }

  .section-head {
    margin-bottom: 12px;

    h3 {
      margin: 0 0 4px;
      color: #1f2a58;
      font-size: 1.1rem;
      font-weight: 700;
    }

    p {
      margin: 0;
      color: #5b6792;
      font-size: 0.92rem;
    }
  }

  .form-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }

  .btn-sm {
    padding: 8px 16px;
    font-size: 13px;
    margin-right: 8px;
    min-width: 70px;
    text-align: center;
    display: inline-block;

    &:last-child {
      margin-right: 0;
    }
  }

  .status-chip {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid transparent;

    &.connected {
      background: #ecfdf3;
      color: #166534;
      border-color: #86efac;
    }

    &.attention {
      background: #fff7ed;
      color: #9a3412;
      border-color: #fdba74;
    }

    &.no-data {
      background: #f3f4f6;
      color: #4b5563;
      border-color: #d1d5db;
    }
  }

  // Action buttons in table
  td.actions {
    white-space: nowrap;

    .btn-sm {
      margin-right: 8px;

      &:last-child {
        margin-right: 0;
      }
    }
  }
}

// Modal overlay (dark background)
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 999;
  backdrop-filter: blur(3px);
  animation: fadeIn 0.3s ease;
}

// Modal container
.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1000;
  max-width: 600px;
  width: 90%;
  animation: slideDown 0.3s ease;

  .modal-content {
    background: white;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    overflow: hidden;

    .modal-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 20px 25px;
      display: flex;
      justify-content: space-between;
      align-items: center;

      h2 {
        margin: 0;
        font-size: 20px;
        color: white;
      }

      .close-btn {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        color: white;
        font-size: 28px;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;

        &:hover {
          background: rgba(255, 255, 255, 0.3);
          transform: rotate(90deg);
        }
      }
    }

    .modal-body {
      padding: 25px;
      max-height: 70vh;
      overflow-y: auto;
    }

    .modal-footer {
      padding: 20px 25px;
      background-color: #f8f9fa;
      border-top: 1px solid #e9ecef;
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }
  }
}

// Animations
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translate(-50%, -60%);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%);
  }
}
