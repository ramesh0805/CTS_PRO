import { Component, OnInit, OnDestroy, ChangeDetectorRef } from '@angular/core';
import { CommonModule } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { TelemetryService } from '../../services/telemetry.service';
import { DeviceService } from '../../services/device.service';
import { TelemetryChartComponent } from '../telemetry-chart/telemetry-chart.component';
import { Device } from '../../models/device.model';
import { Subscription, interval } from 'rxjs';
import { switchMap } from 'rxjs/operators';
import { DeviceMetricMapper, MetricOption } from '../../utils/device-metric-mapper';

@Component({
  selector: 'app-simulator',
  standalone: true,
  imports: [CommonModule, FormsModule, TelemetryChartComponent],
  templateUrl: './simulator.component.html',
  styleUrls: ['./simulator.component.scss']
})
export class SimulatorComponent implements OnInit, OnDestroy {
  devices: Device[] = [];
  selectedDevice: Device | null = null;

  // Live monitoring settings
  simulationRunning = false;
  simulationInterval: any;
  updateIntervalSeconds = 60; // Refresh every 60 seconds to match hourly data updates

  // Metrics to display based on selected device (filtered dynamically)
  metrics: MetricOption[] = [];

  // Chart data from database (live hourly aggregated values)
  chartDataMap: Map<string, any[]> = new Map();

  // Statistics calculated from database values
  statsMap: Map<string, any> = new Map();

  // Messages
  loading = false;
  error = '';
  success = '';

  // Data stream subscriptions
  private subscriptions: Subscription[] = [];
  private liveDataSubscription?: Subscription;

  constructor(
    private deviceService: DeviceService,
    private telemetryService: TelemetryService,
    private cdr: ChangeDetectorRef
  ) {}

  ngOnInit(): void {
    this.loadDevices();
  }

  ngOnDestroy(): void {
    this.stopSimulation();
    this.subscriptions.forEach(sub => sub.unsubscribe());
    if (this.liveDataSubscription) {
      this.liveDataSubscription.unsubscribe();
    }
  }

  loadDevices(): void {
    this.loading = true;
    this.cdr.detectChanges();

    this.deviceService.getAllDevices().subscribe({
      next: (devices) => {
        this.devices = devices;
        if (devices.length > 0) {
          this.selectedDevice = devices[0];
          this.updateMetricsForDevice(); // Set metrics for first device
          this.loadLiveDataFromDatabase();
        }
        this.loading = false;
        this.cdr.detectChanges();
      },
      error: (err) => {
        this.error = 'Failed to load devices';
        this.loading = false;
        this.cdr.detectChanges();
        console.error(err);
      }
    });
  }

  onDeviceChange(): void {
    if (this.selectedDevice) {
      this.updateMetricsForDevice();
      this.loadLiveDataFromDatabase();
    }
  }

  // Determine which metrics are available for the selected device
  updateMetricsForDevice(): void {
    if (!this.selectedDevice) {
      this.metrics = [];
      return;
    }

    this.metrics = DeviceMetricMapper.getMetricsForDevice(
      this.selectedDevice.deviceId,
      this.selectedDevice.name
    );

    console.log(`✅ Updated metrics for ${this.selectedDevice.name}:`, this.metrics.map(m => m.name));
  }

  loadLiveDataFromDatabase(): void {
    if (!this.selectedDevice) return;

    this.loading = true;
    this.error = ''; // Clear any previous errors
    this.cdr.detectChanges();

    // ✅ FETCH LIVE DATA FROM DATABASE ONLY - NO RANDOM GENERATION
    // Uses the same hourly API endpoint as Dashboard and Telemetry pages
    // Returns hourly aggregated data from TelemetryDb for the configured window
    const hours = Math.max(1, Math.ceil(this.updateIntervalSeconds / 3600)) || 24;
    this.telemetryService.getHourlyData(this.selectedDevice.deviceId, undefined, hours).subscribe({
      next: (result: any) => {
        console.log('✅ Loaded live data from database (no random generation):', result);

        // Clear existing data first
        this.chartDataMap.clear();
        this.statsMap.clear();

        // Process the hourly data for each metric from database
        if (result.metrics && Array.isArray(result.metrics)) {
          result.metrics.forEach((metricGroup: any) => {
            const metricName = metricGroup.metric;
            const key = `${this.selectedDevice!.deviceId}-${metricName}`;

            if (metricGroup.data && Array.isArray(metricGroup.data)) {
              // Transform database hourly data to chart format
              // Each dataPoint contains: hour, metric, averageValue, minValue, maxValue, count
              const chartData = metricGroup.data.map((dataPoint: any) => ({
                deviceId: this.selectedDevice!.deviceId,
                metric: dataPoint.metric,
                value: dataPoint.averageValue, // ✅ Using averageValue from database
                timestamp: dataPoint.hour
              }));

              this.chartDataMap.set(key, chartData);
              this.statsMap.set(key, this.calculateStats(chartData));

              console.log(`✅ Loaded ${chartData.length} data points for ${metricName} from database`);
            }
          });
        } else if (result.data && Array.isArray(result.data)) {
          // Single metric response from database
          const key = `${this.selectedDevice!.deviceId}-${result.metric}`;
          const chartData = result.data.map((dataPoint: any) => ({
            deviceId: this.selectedDevice!.deviceId,
            metric: dataPoint.metric,
            value: dataPoint.averageValue, // ✅ Using averageValue from database
            timestamp: dataPoint.hour
          }));

          this.chartDataMap.set(key, chartData);
          this.statsMap.set(key, this.calculateStats(chartData));

          console.log(`✅ Loaded ${chartData.length} data points for ${result.metric} from database`);
        }

        this.loading = false;

        if (this.chartDataMap.size === 0) {
          this.error = 'No data found in database for this device. Please wait for data generation or check device configuration.';
          console.warn('⚠️ No data loaded from database - chartDataMap is empty');
        } else {
          this.success = `Successfully loaded data for ${this.chartDataMap.size} metric(s) from database`;
          // Auto-clear success message after 5 seconds
          setTimeout(() => {
            this.success = '';
            this.cdr.detectChanges();
          }, 5000);
        }

        this.cdr.detectChanges();
      },
      error: (err) => {
        this.error = 'Failed to load live data from database. Please check console for details.';
        this.loading = false;
        this.cdr.detectChanges();
        console.error('❌ Database load error:', err);
        console.error('Error details:', {
          message: err.message,
          status: err.status,
          statusText: err.statusText,
          url: err.url
        });
      }
    });
  }

  calculateStats(data: any[]): any {
    if (!data || data.length === 0) {
      return { min: 0, max: 0, avg: 0, current: 0 };
    }

    const values = data.map(d => d.value);
    return {
      min: Math.min(...values),
      max: Math.max(...values),
      avg: values.reduce((a, b) => a + b, 0) / values.length,
      current: values[values.length - 1]
    };
  }

  startSimulation(): void {
    if (!this.selectedDevice) {
      this.error = 'Please select a device first';
      return;
    }

    this.simulationRunning = true;
    this.error = '';
    this.success = 'Live data monitoring started - refreshing every minute from database';
    // Auto-clear success message after 5 seconds
    setTimeout(() => {
      this.success = '';
    }, 5000);

    // ✅ AUTO-REFRESH DATABASE DATA EVERY CONFIGURED INTERVAL
    // NO random generation - only fetches live hourly data from TelemetryDb
    const hours = Math.max(1, Math.ceil(this.updateIntervalSeconds / 3600)) || 24;
    this.liveDataSubscription = interval(this.updateIntervalSeconds * 1000)
      .pipe(
        switchMap(() => this.telemetryService.getHourlyData(this.selectedDevice!.deviceId, undefined, hours))
      )
      .subscribe({
        next: (result: any) => {
          console.log('✅ Refreshed live data from database (auto-refresh)', result);

          // Update charts with latest database data
          if (result.metrics && Array.isArray(result.metrics)) {
            result.metrics.forEach((metricGroup: any) => {
              const key = `${this.selectedDevice!.deviceId}-${metricGroup.metric}`;

              if (metricGroup.data && Array.isArray(metricGroup.data)) {
                const chartData = metricGroup.data.map((dataPoint: any) => ({
                  deviceId: this.selectedDevice!.deviceId,
                  metric: dataPoint.metric,
                  value: dataPoint.averageValue, // ✅ Database value only
                  timestamp: dataPoint.hour
                }));

                this.chartDataMap.set(key, chartData);
                this.statsMap.set(key, this.calculateStats(chartData));

                console.log(`✅ Auto-refreshed ${chartData.length} points for ${metricGroup.metric}`);
              }
            });
            this.success = `Data refreshed successfully at ${new Date().toLocaleTimeString()}`;
            this.cdr.detectChanges();
            // Auto-clear success message after 5 seconds
            setTimeout(() => {
              this.success = '';
              this.cdr.detectChanges();
            }, 5000);
          }
        },
        error: (err) => {
          console.error('❌ Failed to refresh live data from database:', err);
          this.error = 'Auto-refresh failed. Will retry in next cycle.';
          this.cdr.detectChanges();
        }
      });
  }

  stopSimulation(): void {
    this.simulationRunning = false;
    if (this.simulationInterval) {
      clearInterval(this.simulationInterval);
    }
    if (this.liveDataSubscription) {
      this.liveDataSubscription.unsubscribe();
    }
    this.success = 'Live monitoring stopped';
    // Auto-clear success message after 5 seconds
    setTimeout(() => {
      this.success = '';
    }, 5000);
  }

  generateAndSendData(): void {
    // ✅ REMOVED: This method previously generated random data
    // Now all data comes from database via LiveTelemetryGeneratorService
    console.log('✅ Using live database data only - no manual generation');
  }

  generateSampleData(): void {
    // ✅ RENAMED TO: Refresh database data (no generation)
    // Fetches latest hourly data from TelemetryDb
    if (!this.selectedDevice) {
      this.error = 'Please select a device first';
      return;
    }

    this.loading = true;
    this.loadLiveDataFromDatabase(); // ✅ Only fetches from database
    this.success = 'Refreshed latest data from database';
    // Auto-clear success message after 5 seconds
    setTimeout(() => {
      this.success = '';
    }, 5000);
  }

  getChartData(metric: string): any[] {
    if (!this.selectedDevice) return [];
    const key = `${this.selectedDevice.deviceId}-${metric}`;
    return this.chartDataMap.get(key) || [];
  }

  getStats(metric: string): any {
    if (!this.selectedDevice) return null;
    const key = `${this.selectedDevice.deviceId}-${metric}`;
    return this.statsMap.get(key);
  }

  getVisibleMetrics(): MetricOption[] {
    return this.metrics.filter(metric => this.getChartData(metric.name).length > 0);
  }

  clearData(): void {
    this.chartDataMap.clear();
    this.statsMap.clear();
    this.success = 'Chart data cleared';
    // Auto-clear success message after 5 seconds
    setTimeout(() => {
      this.success = '';
    }, 5000);
  }

  refreshData(): void {
    if (this.selectedDevice) {
      this.loadLiveDataFromDatabase();
    }
  }
}
