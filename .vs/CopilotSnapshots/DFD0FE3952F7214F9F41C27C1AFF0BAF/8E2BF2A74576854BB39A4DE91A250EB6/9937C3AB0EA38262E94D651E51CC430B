import { Component, Input, OnInit, OnDestroy, OnChanges, SimpleChanges, ViewChild, ElementRef, AfterViewInit, ChangeDetectorRef } from '@angular/core';
import { CommonModule } from '@angular/common';
import { Chart, ChartConfiguration, registerables } from 'chart.js';
import { TelemetryService } from '../../services/telemetry.service';
import { ChartData, ChartDataMultiMetric, ChartDataSingleMetric } from '../../models/telemetry.model';
import { Subscription } from 'rxjs';

Chart.register(...registerables);

@Component({
  selector: 'app-telemetry-chart',
  standalone: true,
  imports: [CommonModule],
  template: `
    <div class="chart-container">
      <div class="chart-header">
        <h3>{{ title }}</h3>
        <div class="chart-info" *ngIf="dataPoints">
          <span class="data-points">{{ dataPoints }} points</span>
          <span class="refresh-indicator" *ngIf="autoRefresh" [class.updating]="isUpdating">⟳</span>
        </div>
      </div>
      <div class="chart-wrapper">
        <canvas #chartCanvas></canvas>
      </div>
      <div class="chart-loading" *ngIf="isLoading">
        Loading chart data...
      </div>
      <div class="chart-error" *ngIf="error">
        {{ error }}
      </div>
    </div>
  `,
  styles: [`
    .chart-container {
      background: white;
      border-radius: 8px;
      padding: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      margin-bottom: 20px;
    }

    .chart-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
      border-bottom: 2px solid #f0f0f0;
      padding-bottom: 10px;
    }

    .chart-header h3 {
      margin: 0;
      font-size: 18px;
      font-weight: 600;
      color: #333;
    }

    .chart-info {
      display: flex;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      color: #666;
    }

    .data-points {
      background: #f5f5f5;
      padding: 4px 12px;
      border-radius: 4px;
    }

    .refresh-indicator {
      display: inline-block;
      width: 20px;
      height: 20px;
      background: #f5f5f5;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      color: #999;
      transition: all 0.3s ease;
    }

    .refresh-indicator.updating {
      background: #e3f2fd;
      color: #1976d2;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .chart-wrapper {
      position: relative;
      height: 400px;
      width: 100%;
      margin-bottom: 10px;
    }

    canvas {
      max-height: 400px;
    }

    .chart-loading {
      text-align: center;
      padding: 40px;
      color: #999;
      font-style: italic;
    }

    .chart-error {
      color: #d32f2f;
      padding: 15px;
      background: #ffebee;
      border-radius: 4px;
      text-align: center;
      font-size: 13px;
    }
  `]
})
export class TelemetryChartComponent implements OnInit, OnChanges, AfterViewInit, OnDestroy {
  @ViewChild('chartCanvas', { static: false }) chartCanvas!: ElementRef<HTMLCanvasElement>;

  private readonly localTimeZone: string = Intl.DateTimeFormat().resolvedOptions().timeZone;

  // New properties for API-driven data
  @Input() deviceId?: string;
  @Input() deviceMetric?: string;
  @Input() hours: number = 24;
  @Input() autoRefresh: boolean = true;
  @Input() refreshIntervalMs: number = 30000;
  @Input() title: string = 'Telemetry Chart';

  // Legacy properties (kept for backward compatibility)
  @Input() chartData: any[] = [];
  @Input() chartLabel: string = 'Telemetry Data';
  @Input() chartType: 'line' | 'bar' = 'line';
  @Input() xAxisLabel: string = 'Time';
  @Input() yAxisLabel: string = 'Value';
  @Input() metric: string = '';

  // State
  private chart?: Chart;
  private apiSourceLabels: string[] = [];
  isLoading: boolean = false;
  isUpdating: boolean = false;
  error: string = '';
  dataPoints: number = 0;

  private subscription?: Subscription;
  private chartDataSubscription?: Subscription;

  constructor(
    private telemetryService?: TelemetryService,
    private cdr?: ChangeDetectorRef
  ) {}

  ngOnInit(): void {
    // Check if using new API-driven approach or legacy array-based approach
    if (this.deviceId && this.telemetryService) {
      console.log(`[TelemetryChart] Using API-driven mode for device ${this.deviceId}`);
      this.loadAPIData();
      if (this.autoRefresh) {
        this.startAutoRefresh();
      }
    } else {
      console.log('[TelemetryChart] Using legacy array-based mode');
    }
  }

  ngOnChanges(changes: SimpleChanges): void {
    if (this.deviceId && this.telemetryService) {
      return;
    }

    if (changes['chartData'] && this.chartCanvas) {
      const newData = (changes['chartData'].currentValue as any[]) ?? [];

      if (newData.length === 0) {
        if (this.chart) {
          this.chart.destroy();
          this.chart = undefined;
        }
        return;
      }

      if (this.chart) {
        this.updateChart(newData);
      } else {
        this.createChart();
      }
    }
  }

  ngAfterViewInit(): void {
    // For legacy mode, create chart when initial data is available
    if ((!this.deviceId || !this.telemetryService) && this.chartData?.length > 0) {
      this.createChart();
    }
  }

  ngOnDestroy(): void {
    if (this.chart) {
      this.chart.destroy();
    }
    if (this.subscription) {
      this.subscription.unsubscribe();
    }
    if (this.chartDataSubscription) {
      this.chartDataSubscription.unsubscribe();
    }
  }

  // ===== NEW: API-Driven Methods =====

  private loadAPIData(): void {
    if (!this.deviceId || !this.telemetryService) return;

    this.isLoading = true;
    this.error = '';
    if (this.cdr) this.cdr.detectChanges();

    this.chartDataSubscription = this.telemetryService.getChartData(this.deviceId, this.deviceMetric, this.hours)
      .subscribe({
        next: (chartData: ChartData) => {
          console.log(`[TelemetryChart] Chart data loaded:`, chartData);
          this.renderAPIChart(chartData);
          if (!this.error) { // Only update metadata if no error from render
            this.updateMetadata(chartData);
          }
          this.isLoading = false;
          if (this.cdr) this.cdr.detectChanges();
        },
        error: (error) => {
          console.error('[TelemetryChart] Error loading data:', error);
          this.error = `Failed to load chart data: ${error.status === 0 ? 'Connection refused' : error.statusText}`;
          this.isLoading = false;
          if (this.cdr) this.cdr.detectChanges();
        }
      });
  }

  private startAutoRefresh(): void {
    if (!this.deviceId || !this.telemetryService) return;

    console.log(`[TelemetryChart] Starting auto-refresh every ${this.refreshIntervalMs}ms`);
    this.subscription = this.telemetryService.getLiveChartData(this.deviceId, this.deviceMetric, this.refreshIntervalMs)
      .subscribe({
        next: (chartData: ChartData) => {
          console.log('[TelemetryChart] Auto-refresh update');
          this.isUpdating = true;
          if (this.cdr) this.cdr.detectChanges();

          setTimeout(() => {
            this.updateAPIChart(chartData);
            this.updateMetadata(chartData);
            this.isUpdating = false;
            if (this.cdr) this.cdr.detectChanges();
          }, 200);
        },
        error: (error) => {
          console.error('[TelemetryChart] Auto-refresh error:', error);
        }
      });
  }

  private renderAPIChart(chartData: ChartData): void {
    if (!this.chartCanvas) {
      console.warn('[TelemetryChart] Canvas not found, retrying...');
      setTimeout(() => this.renderAPIChart(chartData), 100);
      return;
    }

    const ctx = this.chartCanvas.nativeElement.getContext('2d');
    if (!ctx) {
      console.error('[TelemetryChart] Could not get 2D context');
      return;
    }

    // Check if data is empty
    const isMultiMetric = 'datasets' in chartData;
    let hasData = false;

    if (isMultiMetric) {
      const data = chartData as ChartDataMultiMetric;
      hasData = data.labels && data.labels.length > 0 && data.datasets && data.datasets.length > 0;
    } else {
      const data = chartData as ChartDataSingleMetric;
      hasData = data.labels && data.labels.length > 0 && data.dataset && data.dataset.data && data.dataset.data.length > 0;
    }

    if (!hasData) {
      console.log('[TelemetryChart] No data available for chart, showing placeholder');
      this.error = 'No data available yet. Waiting for telemetry data...';
      this.isLoading = false;
      if (this.cdr) this.cdr.detectChanges();
      return;
    }

    if (this.chart) {
      this.chart.destroy();
    }

    const config = this.buildAPIChartConfig(chartData, isMultiMetric);

    try {
      this.chart = new Chart(ctx, config);
      console.log('[TelemetryChart] Chart rendered successfully');
      this.error = '';
    } catch (error) {
      console.error('[TelemetryChart] Error rendering:', error);
      this.error = 'Failed to render chart';
    }
  }

  private updateAPIChart(chartData: ChartData): void {
    if (!this.chart) {
      this.renderAPIChart(chartData);
      return;
    }

    const isMultiMetric = 'datasets' in chartData;
    if (isMultiMetric) {
      const data = chartData as ChartDataMultiMetric;
      this.apiSourceLabels = [...data.labels];
      this.chart.data.labels = data.labels.map(label => this.formatLabelForAxis(label));
      this.chart.data.datasets = data.datasets as any;
    } else {
      const data = chartData as ChartDataSingleMetric;
      this.apiSourceLabels = [...data.labels];
      this.chart.data.labels = data.labels.map(label => this.formatLabelForAxis(label));
      this.chart.data.datasets = [data.dataset] as any;
    }

    this.chart.update('none'); // Update without animation
  }

  private buildAPIChartConfig(chartData: ChartData, isMultiMetric: boolean): ChartConfiguration {
    let labels: string[] = [];
    let datasets: any[] = [];

    if (isMultiMetric) {
      const data = chartData as ChartDataMultiMetric;
      this.apiSourceLabels = [...data.labels];
      labels = data.labels.map(label => this.formatLabelForAxis(label));
      datasets = data.datasets;
    } else {
      const data = chartData as ChartDataSingleMetric;
      this.apiSourceLabels = [...data.labels];
      labels = data.labels.map(label => this.formatLabelForAxis(label));
      datasets = [data.dataset];
    }

    return {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { intersect: false, mode: 'index' },
        plugins: {
          legend: {
            display: true,
            position: 'top',
            labels: {
              usePointStyle: true,
              padding: 15,
              font: { size: 12, weight: 'bold' }
            }
          },
          tooltip: {
            backgroundColor: 'rgba(0, 0, 0, 0.8)',
            padding: 12,
            titleFont: { size: 13, weight: 'bold' },
            bodyFont: { size: 12 },
            displayColors: true,
            callbacks: {
              title: (context: any[]) => {
                const index = context?.[0]?.dataIndex;
                if (index === undefined || index === null || !this.apiSourceLabels[index]) {
                  return '';
                }
                const asDate = new Date(this.apiSourceLabels[index]);
                if (Number.isNaN(asDate.getTime())) {
                  return this.apiSourceLabels[index];
                }
                return asDate.toLocaleString('en-US', { timeZone: this.localTimeZone, timeZoneName: 'short' });
              },
              label: (context: any) => {
                let label = context.dataset.label || '';
                if (label) label += ': ';
                label += context.parsed.y.toFixed(2);
                return label;
              }
            }
          }
        },
        scales: {
          y: {
            type: 'linear',
            display: true,
            beginAtZero: false,
            grid: { display: true, color: 'rgba(0, 0, 0, 0.05)' },
            ticks: { color: '#666', font: { size: 11 } }
          },
          x: {
            display: true,
            grid: { display: false },
            ticks: { color: '#666', font: { size: 11 }, maxTicksLimit: 12 }
          }
        }
      } as any
    };
  }

  private updateMetadata(chartData: ChartData): void {
    const isMultiMetric = 'datasets' in chartData;
    const data = isMultiMetric ? (chartData as ChartDataMultiMetric) : (chartData as ChartDataSingleMetric);
    this.dataPoints = data.dataPointCount;
  }

  private formatLabelForAxis(value: string): string {
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return value;
    }

    return date.toLocaleString('en-US', {
      hour: '2-digit',
      minute: '2-digit',
      month: 'short',
      day: '2-digit',
      timeZone: this.localTimeZone
    });
  }

  // ===== LEGACY: Array-Based Methods (backward compatible) =====

  private createChart(): void {
    if (!this.chartCanvas || !this.chartData || this.chartData.length === 0) {
      return;
    }

    if (this.chart) {
      this.chart.destroy();
      this.chart = undefined;
    }

    const ctx = this.chartCanvas.nativeElement.getContext('2d');
    if (!ctx) return;

    // Calculate time span to determine best X-axis format
    const timeSpanHours = this.calculateTimeSpan(this.chartData);

    const labels = this.chartData.map((d, index) => {
      return this.formatTimestampForAxis(d.timestamp, index, this.chartData.length, timeSpanHours);
    });

    const data = this.chartData.map(d => d.value);

    const config: ChartConfiguration = {
      type: this.chartType,
      data: {
        labels: labels,
        datasets: [{
          label: this.chartLabel,
          data: data,
          borderColor: 'rgb(75, 192, 192)',
          backgroundColor: 'rgba(75, 192, 192, 0.2)',
          tension: 0.4,
          fill: true,
          pointRadius: timeSpanHours <= 12 ? 4 : (timeSpanHours > 12 ? 2 : 0),  // Larger points for hourly data
          pointHoverRadius: 6,
          pointBackgroundColor: 'rgb(75, 192, 192)',
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: true,
            position: 'top',
          },
          tooltip: {
            mode: 'index',
            intersect: false,
            callbacks: {
              title: (context) => {
                const dataIndex = context[0].dataIndex;
                const timestamp = this.chartData[dataIndex].timestamp;
                return new Date(timestamp).toLocaleString();
              },
              label: (context) => {
                const value = context.parsed.y;
                return `${this.chartLabel}: ${value?.toFixed(2) ?? 'N/A'}`;
              }
            }
          }
        },
        scales: {
          x: {
            display: true,
            title: {
              display: true,
              text: timeSpanHours > 48 ? 'Date' : 'Time'
            },
            ticks: {
              maxRotation: 45,
              minRotation: 0,
              autoSkip: false, // Show all labels for hourly data
              maxTicksLimit: timeSpanHours > 24 ? 24 : (timeSpanHours <= 12 ? 12 : 12)
            }
          },
          y: {
            display: true,
            title: {
              display: true,
              text: this.yAxisLabel
            },
            min: this.getYAxisMin(),
            max: this.getYAxisMax(),
            ticks: {
              callback: (value) => {
                return Number(value).toFixed(1);
              }
            }
          }
        },
        interaction: {
          mode: 'nearest',
          axis: 'x',
          intersect: false
        }
      }
    };

    this.chart = new Chart(ctx, config);
  }

  private calculateTimeSpan(data: any[]): number {
    if (data.length < 2) return 0;

    const firstTime = new Date(data[0].timestamp).getTime();
    const lastTime = new Date(data[data.length - 1].timestamp).getTime();
    const diffMs = Math.abs(lastTime - firstTime);
    const diffHours = diffMs / (1000 * 60 * 60);

    return diffHours;
  }

  private formatTimestampForAxis(timestamp: string, index: number, totalPoints: number, timeSpanHours: number): string {
    const date = new Date(timestamp);

    // For hourly data (typical for simulator/dashboard), show actual time
    if (totalPoints <= 12 && timeSpanHours <= 12) {
      // Show actual hour and minute (e.g., "10:00 AM", "11:00 AM")
      return date.toLocaleTimeString('en-US', { 
        hour: '2-digit', 
        minute: '2-digit',
        hour12: true 
      });
    }

    // For data spanning more than 12 hours, show date + time
    if (timeSpanHours >= 12) {
      // Show date and time for longer periods
      if (timeSpanHours > 48) {
        // For multi-day data, show date (e.g., "Jan 15")
        return date.toLocaleDateString('en-US', { 
          month: 'short', 
          day: 'numeric' 
        });
      } else {
        // For 12-48 hours, show time only
        return date.toLocaleTimeString('en-US', { 
          hour: '2-digit', 
          minute: '2-digit',
          hour12: true 
        });
      }
    } else {
      // For shorter time spans, show full time
      return date.toLocaleTimeString('en-US', { 
        hour: '2-digit', 
        minute: '2-digit',
        hour12: true 
      });
    }
  }

  private getYAxisMin(): number | undefined {
    // Set metric-specific minimum values for Y-axis
    switch (this.metric.toLowerCase()) {
      case 'temperature':
        return 25; // Temperature range: 25°C to 48°C for Indian climate
      case 'humidity':
        return 0; // Humidity: 0% to 100%
      case 'pressure':
        return undefined; // Pressure: auto-scale (typically 1000-1020 hPa)
      default:
        return undefined; // Auto-scale for unknown metrics
    }
  }

  private getYAxisMax(): number | undefined {
    // Set metric-specific maximum values for Y-axis
    switch (this.metric.toLowerCase()) {
      case 'temperature':
        return 48; // Temperature range: 25°C to 48°C for Indian climate
      case 'humidity':
        return 100; // Humidity: 0% to 100%
      case 'pressure':
        return undefined; // Pressure: auto-scale (typically 1000-1020 hPa)
      default:
        return undefined; // Auto-scale for unknown metrics
    }
  }

  public updateChart(newData: any[]): void {
    if (!this.chart) return;

    this.chartData = newData;
    const timeSpanHours = this.calculateTimeSpan(newData);

    const labels = newData.map((d, index) => {
      return this.formatTimestampForAxis(d.timestamp, index, newData.length, timeSpanHours);
    });

    const data = newData.map(d => d.value);

    this.chart.data.labels = labels;
    this.chart.data.datasets[0].data = data;

    // Update point radius based on data size
    if (this.chart.data.datasets[0]) {
      (this.chart.data.datasets[0] as any).pointRadius = timeSpanHours <= 12 ? 4 : (timeSpanHours > 12 ? 2 : 0);
      (this.chart.data.datasets[0] as any).pointHoverRadius = 6;
    }

    // Update X-axis title and ticks
    if (this.chart.options.scales && this.chart.options.scales['x']) {
      const xScale = this.chart.options.scales['x'] as any;
      if (xScale.title) {
        xScale.title.text = timeSpanHours >= 12 ? 'Time (Hours)' : 'Hours Ago';
      }
      if (xScale.ticks) {
        xScale.ticks.autoSkip = false; // Show all labels
      }
    }

    this.chart.update();
  }
}
