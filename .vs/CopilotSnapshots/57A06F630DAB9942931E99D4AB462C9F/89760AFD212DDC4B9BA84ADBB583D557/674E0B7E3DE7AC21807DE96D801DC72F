/* =====================================================
   GLOBAL STYLES — MQTT Telemetry Collector
   ===================================================== */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --bg-start: #f4f7ff;
  --bg-end:   #edf2ff;
  --text-primary:   #1e2340;
  --text-secondary: #5b6488;
  --text-muted:     #8b93b8;
  --card-bg:        rgba(255, 255, 255, 0.96);
  --primary:        #4f46e5;
  --primary-2:      #2563eb;
  --success:        #16a34a;
  --danger:         #dc2626;
  --warning:        #f59e0b;
  --info:           #0ea5e9;
  --border:         rgba(79, 70, 229, 0.13);
  --shadow-sm:      0 2px 8px rgba(30, 35, 80, 0.08);
  --shadow-md:      0 8px 24px rgba(30, 35, 80, 0.12);
  --shadow-lg:      0 16px 40px rgba(30, 35, 80, 0.16);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
}

html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
  overflow-x: hidden;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  background: radial-gradient(circle at top left, #ffffff 0%, var(--bg-start) 45%, var(--bg-end) 100%);
  color: var(--text-primary);
  font-size: 14px;
  line-height: 1.5;
}

/* ─── Page Wrapper ─────────────────────────────────── */
.page {
  max-width: 1400px;
  margin: 0 auto;
  padding: 28px 24px 48px;

  @media (max-width: 768px) { padding: 18px 14px 32px; }
}

.page-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 28px;
  flex-wrap: wrap;

  &__text {
    h1 {
      margin: 0 0 5px;
      font-size: 1.85rem;
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1.2;
    }
    p {
      margin: 0;
      color: var(--text-secondary);
      font-size: 0.93rem;
      line-height: 1.5;
    }
  }

  &__actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }
}

/* ─── Cards ─────────────────────────────────────────── */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 22px;
  margin-bottom: 20px;
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
  backdrop-filter: blur(6px);

  &:last-child { margin-bottom: 0; }
}

.card-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--border);

  &__icon { font-size: 18px; line-height: 1; }

  h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    flex: 1;
  }

  &__badge {
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    background: #e0e7ff;
    color: #3730a3;
    white-space: nowrap;
  }
}

/* ─── Buttons ────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 9px 18px;
  border: none;
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
  transition: all 0.2s ease;
  text-decoration: none;

  &:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  &:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none !important;
  }

  &.btn-primary  { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-2) 100%); color: #fff; }
  &.btn-success  { background: linear-gradient(135deg, #22c55e 0%, var(--success) 100%); color: #fff; }
  &.btn-danger   { background: linear-gradient(135deg, #ef4444 0%, var(--danger) 100%); color: #fff; }
  &.btn-warning  { background: linear-gradient(135deg, #fbbf24 0%, var(--warning) 100%); color: #1a1200; }
  &.btn-info     { background: linear-gradient(135deg, #38bdf8 0%, var(--info) 100%); color: #fff; }
  &.btn-secondary{ background: linear-gradient(135deg, #8b94b3 0%, #6c757d 100%); color: #fff; }
  &.btn-ghost    { background: transparent; color: var(--primary); border: 1px solid var(--border);
    &:hover:not(:disabled) { background: #eef2ff; } }

  &.btn-sm { padding: 6px 12px; font-size: 12px; border-radius: 6px; }
  &.btn-lg { padding: 12px 24px; font-size: 15px; }
  &.btn-icon { padding: 8px; border-radius: 50%; }
}

/* ─── Forms ──────────────────────────────────────────── */
.form-group {
  margin-bottom: 16px;

  label {
    display: block;
    margin-bottom: 6px;
    font-weight: 600;
    font-size: 13px;
    color: var(--text-primary);
  }

  input, textarea, select {
    width: 100%;
    padding: 10px 13px;
    border: 1px solid #d1d8f0;
    border-radius: var(--radius-sm);
    font-size: 14px;
    background: #fff;
    color: var(--text-primary);
    transition: border-color 0.2s, box-shadow 0.2s;

    &:focus {
      outline: none;
      border-color: var(--primary-2);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.14);
    }

    &:disabled {
      background: #f3f4f6;
      color: #9ca3af;
      cursor: not-allowed;
    }
  }

  textarea { resize: vertical; min-height: 80px; }
}

/* ─── Tables ─────────────────────────────────────────── */
.table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13.5px;

  th, td {
    padding: 11px 14px;
    text-align: left;
    border-bottom: 1px solid #e8edf8;
  }

  th {
    background: linear-gradient(135deg, #eef2ff 0%, #dbeafe 100%);
    color: #1e3a7a;
    font-weight: 700;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    white-space: nowrap;
  }

  tbody tr {
    transition: background 0.15s;

    &:hover { background: #f5f7ff; }
    &:last-child td { border-bottom: none; }
  }
}

/* ─── Alerts ─────────────────────────────────────────── */
.alert {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 18px;
  border-radius: var(--radius-sm);
  margin-bottom: 18px;
  font-size: 13.5px;
  font-weight: 500;

  &.alert-success { background: #dcfce7; color: #14532d; border: 1px solid #86efac; }
  &.alert-error   { background: #fee2e2; color: #7f1d1d; border: 1px solid #fca5a5; }
  &.alert-info    { background: #e0f2fe; color: #0c4a6e; border: 1px solid #7dd3fc; }
  &.alert-warning { background: #fef9c3; color: #713f12; border: 1px solid #fde047; }
}

/* ─── Loading ────────────────────────────────────────── */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14px;
  padding: 60px 20px;
  color: var(--text-secondary);
  font-size: 14px;

  .spinner {
    width: 28px;
    height: 28px;
    border: 3px solid #c7d2fe;
    border-top-color: var(--primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ─── Badges / Chips ─────────────────────────────────── */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.3px;

  &.badge-green  { background: #dcfce7; color: #166534; }
  &.badge-red    { background: #fee2e2; color: #991b1b; }
  &.badge-blue   { background: #dbeafe; color: #1e40af; }
  &.badge-orange { background: #ffedd5; color: #9a3412; }
  &.badge-gray   { background: #f3f4f6; color: #4b5563; }
  &.badge-purple { background: #ede9fe; color: #6b21a8; }
}

/* ─── Grid ───────────────────────────────────────────── */
.grid {
  display: grid;
  gap: 20px;

  &.grid-2 { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
  &.grid-3 { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  &.grid-4 { grid-template-columns: repeat(4, 1fr);
    @media (max-width: 900px) { grid-template-columns: repeat(2, 1fr); }
    @media (max-width: 480px) { grid-template-columns: 1fr; }
  }
}

/* ─── Modal ──────────────────────────────────────────── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 15, 40, 0.55);
  z-index: 900;
  backdrop-filter: blur(4px);
  animation: fadeOverlay 0.2s ease;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1000;
  width: min(580px, 92vw);
  animation: slideModal 0.25s ease;

  .modal-content {
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .modal-header {
    background: linear-gradient(135deg, #4f46e5 0%, #2563eb 100%);
    color: #fff;
    padding: 18px 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;

    h2 { margin: 0; font-size: 17px; font-weight: 700; color: #fff; }

    .close-btn {
      background: rgba(255,255,255,0.2);
      border: none;
      color: #fff;
      font-size: 22px;
      width: 34px; height: 34px;
      border-radius: 50%;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s, transform 0.2s;
      line-height: 1;

      &:hover { background: rgba(255,255,255,0.32); transform: rotate(90deg); }
    }
  }

  .modal-body {
    padding: 22px;
    max-height: 65vh;
    overflow-y: auto;
  }

  .modal-footer {
    padding: 16px 22px;
    background: #f8f9fd;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }
}

@keyframes fadeOverlay { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideModal {
  from { opacity: 0; transform: translate(-50%, -58%); }
  to   { opacity: 1; transform: translate(-50%, -50%); }
}

/* ─── Pagination ─────────────────────────────────────── */
.pagination {
  display: flex;
  gap: 6px;
  justify-content: center;
  margin-top: 20px;
  flex-wrap: wrap;

  button {
    padding: 7px 13px;
    border: 1px solid #d1d8f0;
    background: #fff;
    cursor: pointer;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    transition: all 0.18s;

    &:hover:not(:disabled) {
      background: var(--primary);
      color: #fff;
      border-color: var(--primary);
    }

    &:disabled { cursor: not-allowed; opacity: 0.45; }
    &.active { background: var(--primary); color: #fff; border-color: var(--primary); }
  }
}

/* ─── Status / Empty states ──────────────────────────── */
.empty-state {
  text-align: center;
  padding: 50px 20px;
  color: var(--text-muted);

  .empty-icon { font-size: 42px; margin-bottom: 12px; }
  p { font-size: 14px; line-height: 1.6; }
}

/* ─── Nav (legacy keep) ──────────────────────────────── */
.nav {
  background: linear-gradient(90deg, #312e81 0%, #1d4ed8 45%, #0ea5e9 100%);
  padding: 15px 0;
  margin-bottom: 30px;
  box-shadow: 0 8px 18px rgba(29, 78, 216, 0.26);

  ul {
    list-style: none;
    display: flex;
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;

    li a {
      color: white;
      text-decoration: none;
      padding: 8px 16px;
      border-radius: 8px;
      transition: background-color 0.3s;

      &:hover, &.active { background-color: rgba(255,255,255,0.22); }
    }
  }
}


